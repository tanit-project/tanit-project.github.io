  }
  .preset-img-btn:hover { border-color: rgba(173,101,191,.5); transform: translateY(-2px); }
  .preset-img-btn.selected { border-color: #AD65BF; box-shadow: 0 0 0 3px rgba(173,101,191,.2); }
  .preset-label {
