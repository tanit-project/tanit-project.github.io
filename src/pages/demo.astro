---
import '../styles/global.css';
---

<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>TANIT — İnteraktif Demo</title>
  <link rel="icon" href="/tanit-logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@1,600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- DEMO BANNER -->
<div id="demo-banner">
  🎮 İnteraktif Demo — hesap gerekmez, özgürce keşfet
  <button id="close-banner" aria-label="Kapat">×</button>
</div>

<!-- APP SHELL -->
<div id="app">

  <!-- ══════════════ SIDEBAR ══════════════ -->
  <aside id="sidebar">

    <!-- Logo -->
    <div id="sidebar-logo">
      <a href="/" id="logo-link">
        <img src="/tanit-logo.svg" id="logo-img" alt="TANIT" />
      </a>
    </div>

    <!-- Collapse toggle -->
    <button id="collapse-btn" onclick="toggleSidebar()" aria-label="Sidebar">
      <svg id="collapse-icon-left" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <svg id="collapse-icon-right" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="hidden"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>

    <!-- Navigation -->
    <nav id="sidebar-nav">
      <button class="nav-item active" data-key="dashboard" onclick="gotoView('dashboard')">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1" stroke-width="2"/></svg>
        <span class="nav-label">Kontrol Paneli</span>
        <div class="active-bar"></div>
      </button>
      <button class="nav-item" data-key="create" onclick="gotoView('create')">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="9" stroke-width="2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v8M8 12h8"/></svg>
        <span class="nav-label">Oluştur+</span>
        <div class="active-bar"></div>
      </button>
      <button class="nav-item" data-key="campaigns" onclick="gotoView('campaigns')">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
        <span class="nav-label">Kampanyalar</span>
        <div class="active-bar"></div>
      </button>
      <button class="nav-item" data-key="scheduled" onclick="gotoView('scheduled')">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="4" width="18" height="18" rx="2" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M16 2v4M8 2v4M3 10h18"/></svg>
        <span class="nav-label">Planlananlar</span>
        <div class="active-bar"></div>
      </button>
      <button class="nav-item" data-key="profile" onclick="gotoView('profile')">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="8" r="4" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M4 20c0-4 3.582-7 8-7s8 3 8 7"/></svg>
        <span class="nav-label">Profil</span>
        <div class="active-bar"></div>
      </button>
      <button class="nav-item" data-key="settings" onclick="gotoView('settings')">
        <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3" stroke-width="2"/></svg>
        <span class="nav-label">Ayarlar</span>
        <div class="active-bar"></div>
      </button>
    </nav>

    <!-- User footer -->
    <div id="sidebar-footer">
      <button id="theme-toggle-btn" class="footer-btn">
        <svg id="theme-icon" class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="5" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <span class="nav-label">Aydınlık Mod</span>
      </button>
      <div id="user-row">
        <div id="user-avatar">D</div>
        <div id="user-info" class="nav-label-block">
          <p id="user-name">Demo User</p>
          <p id="user-email">demo@tanit.app</p>
        </div>
        <button id="logout-btn" title="Çıkış">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        </button>
      </div>
    </div>

  </aside>

  <!-- ══════════════ MAIN ══════════════ -->
  <main id="main-content">

    <!-- Breadcrumb -->
    <nav id="breadcrumb" class="bc hidden"></nav>

    <!-- ────────────────────────────────────
         VIEW: DASHBOARD
    ──────────────────────────────────── -->
    <div id="view-dashboard" class="view" style="max-width:56rem;margin:0 auto">

      <!-- Hero -->
      <div style="text-align:center;padding:3.5rem 1rem 2.5rem">
        <h1 class="display-heading gradient-text" style="font-size:2.375rem;line-height:1.25">
          Ürün fotoğrafını Instagram<br>gönderisine dönüştür
        </h1>
        <p class="muted-text" style="margin-top:.875rem;font-size:1rem">Dakikalar içinde. Yapay zeka ile.</p>
      </div>

      <!-- Feature cards -->
      <div class="dash-feature-grid">

        <div class="dash-feature-card" style="--card-glow:rgba(109,40,217,.18);--card-border:rgba(109,40,217,.35)">
          <div class="dash-feature-icon" style="background:rgba(109,40,217,.18)">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#A78BFA"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><circle cx="12" cy="13" r="3" stroke-width="2"/></svg>
          </div>
          <h3 class="dash-feature-title">AI Fotoğraf Çekimi</h3>
          <p class="dash-feature-desc">Ürün görselini flatlay, model üstünde veya kullanım halinde stüdyo çekimine dönüştür — fotoğrafçı gerekmez.</p>
        </div>

        <div class="dash-feature-card" style="--card-glow:rgba(146,64,14,.2);--card-border:rgba(217,119,6,.3)">
          <div class="dash-feature-icon" style="background:rgba(180,83,9,.18)">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#fbbf24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2h-4M9 3a3 3 0 006 0M9 3h6"/></svg>
          </div>
          <h3 class="dash-feature-title">Sanal Model Denemesi</h3>
          <p class="dash-feature-desc">Kıyafetini AI model üzerinde giydir, farklı beden ve stillerde gerçekçi sonuçlar gör.</p>
        </div>

        <div class="dash-feature-card" style="--card-glow:rgba(6,78,59,.2);--card-border:rgba(16,185,129,.25)">
          <div class="dash-feature-icon" style="background:rgba(6,95,70,.2)">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#34d399"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          </div>
          <h3 class="dash-feature-title">Doğrudan Instagram'a</h3>
          <p class="dash-feature-desc">AI başlık ve etiket yazar, istediğin saatte planlar ve Instagram hesabına otomatik yayınlar.</p>
        </div>

      </div>

      <!-- CTA -->
      <div style="text-align:center;padding:2rem 0 1rem">
        <button class="gradient-btn" onclick="gotoView('create')"
          style="padding:.9375rem 2.5rem;border-radius:.875rem;font-size:1rem;display:inline-flex;align-items:center;gap:.625rem">
          İlk Gönderini Oluştur
        </button>
      </div>

    </div>

    <!-- ────────────────────────────────────
         VIEW: CREATE
    ──────────────────────────────────── -->
    <div id="view-create" class="view hidden" style="max-width:42rem;margin:0 auto">

      <!-- COMPOSE SUB-VIEW -->
      <div id="create-compose">
        <header style="text-align:center;margin-bottom:2rem">
          <h1 class="display-heading gradient-text" style="font-size:2.25rem">Yeni Gönderi Oluştur</h1>
          <p class="muted-text" style="margin-top:.5rem">Ürün görsellerinizi yükleyin ve AI mükemmel başlığı yazsın.</p>
        </header>

        <!-- Composer card -->
        <div id="composer-card">
          <!-- Attached image thumbnail -->
          <div id="composer-thumb" class="hidden">
            <div style="position:relative;display:inline-block">
              <div id="composer-thumb-img-wrap">
                <img id="composer-thumb-img" src="/photos-generated/non-AI.jpeg" alt="Yüklenen" />
              </div>
              <button onclick="removeComposerImage()" id="thumb-remove-btn" aria-label="Kaldır">×</button>
            </div>
          </div>

          <!-- Textarea -->
          <textarea id="composer-textarea" rows="4"
            placeholder="örn. Sıcak kafe atmosferi, ahşap masa, sabah ışığı — huzurlu bir ortam."></textarea>

          <!-- Bottom bar -->
          <div id="composer-bar">
            <div id="composer-chips">
              <button class="chip" id="upload-chip" onclick="showPresetPicker()">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Görsel Yükle
              </button>
              <button class="chip active" id="ai-toggle-btn" onclick="toggleAI()" data-ai="on">
                <svg id="ai-icon-zap" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                <svg id="ai-icon-zapoff" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="hidden"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17l-5-5m0 0L7 7m5 5l5-5m-5 5l-5 5"/></svg>
                AI <span id="ai-label">On</span>
              </button>
            </div>
            <button id="composer-continue-btn" class="gradient-btn" onclick="onComposerContinue()"
              style="padding:.5rem 1.125rem;border-radius:.625rem;font-size:.875rem;display:flex;align-items:center;gap:.375rem;flex-shrink:0">
              <svg id="continue-img-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <span id="continue-btn-text">Görsel Yükle</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </button>
          </div>
        </div>

        <!-- AI Settings panel -->
        <div id="ai-settings-panel" class="hidden">
          <p class="settings-label">AI AYARLARI</p>
          <div class="settings-grid">
            <div>
              <label class="settings-field-label">Hedef Cinsiyet</label>
              <div style="position:relative">
                <select id="gender-select" class="settings-select">
                  <option value="">Tümü</option>
                  <option value="female">Kadın</option>
                  <option value="male">Erkek</option>
                  <option value="unisex">Unisex</option>
                </select>
                <svg style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);pointer-events:none" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </div>
            </div>
            <div>
              <label class="settings-field-label">Yaş Grubu</label>
              <div style="position:relative">
                <select id="age-select" class="settings-select">
                  <option value="">Tümü</option>
                  <option value="young">Genç</option>
                  <option value="adult">Yetişkin</option>
                  <option value="child">Çocuk</option>
                </select>
                <svg style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);pointer-events:none" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Preset image picker -->
        <div id="preset-picker" class="hidden">
          <p class="settings-label" style="margin-bottom:.75rem">ÖRNEK FOTOĞRAFLAR</p>
          <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:.75rem;max-width:22rem">
            <button class="preset-btn" id="preset-a" onclick="selectPreset('/photos-generated/non-AI.jpeg','preset-a')">
              <img src="/photos-generated/non-AI.jpeg" alt="Ürün fotoğrafı" style="width:100%;height:100%;object-fit:contain"/>
              <div class="preset-label-overlay">🧥 Ürün Fotoğrafı</div>
            </button>
            <button class="preset-btn" id="preset-b" onclick="selectPreset('/photos-generated/02.png','preset-b')">
              <img src="/photos-generated/02.png" alt="Düz çekim" style="width:100%;height:100%;object-fit:cover"/>
              <div class="preset-label-overlay">📸 Düz Çekim</div>
            </button>
          </div>
        </div>
      </div>

      <!-- TEMPLATE SELECTION SUB-VIEW -->
      <div id="create-templates" class="hidden">
        <div class="two-panel">

          <!-- Left: product image -->
          <div class="panel-card">
            <div class="panel-card-header">
              <h2 class="panel-title">Ürün Görseli</h2>
              <button class="icon-circle-btn" onclick="backToCompose()" title="Değiştir">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
              </button>
            </div>
            <div class="product-img-wrap">
              <img id="product-preview-img" src="/photos-generated/non-AI.jpeg" alt="Ürün" style="width:100%;height:100%;object-fit:contain"/>
            </div>
          </div>

          <!-- Right: templates -->
          <div class="panel-card">
            <div class="panel-card-header">
              <h2 class="panel-title">Çekim Şablonları</h2>
            </div>
            <div class="template-grid" id="template-grid">
              <button class="tpl-btn selected" data-id="flatlay" onclick="toggleTemplate(this)">
                <div class="tpl-bg" style="background-image:url('/demo-tpl-flatlay.png');background-size:cover;background-position:center"></div>
                <div class="tpl-overlay"></div>
                <span class="tpl-label">Düz Çekim</span>
                <div class="tpl-check">✓</div>
              </button>
              <button class="tpl-btn selected" data-id="model_tryon" onclick="toggleTemplate(this)">
                <div class="tpl-bg" style="background-image:url('/demo-tpl-model.png');background-size:cover;background-position:top center"></div>
                <div class="tpl-overlay"></div>
                <span class="tpl-label">Model Dene</span>
                <div class="tpl-check">✓</div>
              </button>
              <button class="tpl-btn" data-id="in_use" onclick="toggleTemplate(this)">
                <div class="tpl-bg" style="background-image:url('/demo-tpl-reklam.png');background-size:cover;background-position:center"></div>
                <div class="tpl-overlay"></div>
                <span class="tpl-label">Reklam</span>
                <div class="tpl-check">✓</div>
              </button>
              <button class="tpl-btn" data-id="collage" onclick="toggleTemplate(this)">
                <div class="tpl-bg" style="background-image:url('/demo-tpl-kolaj.png');background-size:cover;background-position:center"></div>
                <div class="tpl-overlay"></div>
                <span class="tpl-label">Kolaj</span>
                <div class="tpl-check">✓</div>
              </button>
              <button class="tpl-btn" data-id="back_shot" onclick="toggleTemplate(this)">
                <div class="tpl-bg" style="background-image:url('/demo-tpl-arka.png');background-size:cover;background-position:center"></div>
                <div class="tpl-overlay"></div>
                <span class="tpl-label">Arka Görünüm</span>
                <div class="tpl-check">✓</div>
              </button>
              <button class="tpl-btn selected" data-id="photoshoot" onclick="toggleTemplate(this)">
                <div class="tpl-bg" style="background-image:url('/demo-tpl-fotograf.png');background-size:cover;background-position:top center"></div>
                <div class="tpl-overlay"></div>
                <span class="tpl-label">Fotoğraf Çekimi</span>
                <div class="tpl-check">✓</div>
              </button>
            </div>
          </div>
        </div>
        <p class="muted-text" style="font-size:.75rem;margin-top:.875rem;text-align:center">Eğer kıyafetin arka ya da sırt kısmını yüklemezseniz model tahmin etmeye çalışır ve performans düşer.</p>

        <!-- Prompt readonly textarea -->
        <textarea id="template-prompt-display" class="prompt-readonly" rows="2" readonly
          placeholder="Sahne tarifiniz burada görünecek…"></textarea>

        <!-- Actions -->
        <div style="display:flex;justify-content:flex-end;margin-top:.75rem">
          <button class="gradient-btn" id="generate-btn" onclick="startGenerate()"
            style="padding:.625rem 1.375rem;border-radius:.625rem;font-size:.9375rem;display:flex;align-items:center;gap:.5rem">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/></svg>
            Oluştur
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- ────────────────────────────────────
         VIEW: PREVIEW
    ──────────────────────────────────── -->
    <div id="view-preview" class="view hidden" style="max-width:56rem;margin:0 auto">

      <!-- Preview header row -->
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1.75rem;flex-wrap:wrap">
        <div>
          <h1 class="display-heading" style="font-size:1.875rem;font-weight:700">Gönderinizi Seçin</h1>
          <p class="muted-text" style="margin-top:.25rem;font-size:.875rem">Sizin için 5 varyasyon oluşturduk. Favorinizi seçin.</p>
        </div>
        <div style="display:flex;gap:.625rem;flex-shrink:0;flex-wrap:wrap">
          <button class="outline-btn" onclick="resetCreateFlow()" style="display:flex;align-items:center;gap:.375rem;font-size:.8125rem;padding:.4375rem .875rem">
