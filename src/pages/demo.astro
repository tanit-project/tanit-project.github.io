<!-- ═══════════════════════════════════════════
     STYLES
═══════════════════════════════════════════ -->
<style>
  /* ── Tokens ── */
  :root {
    --bg:         #080612;
    --sidebar-bg: #0d0920;
    --surface:    #130E24;
    --elevated:   #1D1638;
    --border:     rgba(49,40,96,.85);
    --muted-bg:   rgba(196,181,253,.055);
    --muted-fg:   rgba(196,181,253,.45);
    --fg:         #F5F3FF;
    --accent:     #6D28D9;
    --accent-h:   #7C3AED;
    --accent-lt:  #A78BFA;
    --accent-s:   rgba(109,40,217,.15);
    --sidebar-w:  18rem;
    --sidebar-w-c: 5rem;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: Inter, system-ui, -apple-system, sans-serif;
    overflow: hidden;
    height: 100dvh;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Demo Banner ── */
  #demo-banner {
    position: fixed; top: 0; left: 0; right: 0; z-index: 60;
    height: 2.5rem;
    background: var(--accent);
    display: flex; align-items: center; justify-content: center;
    font-size: .8125rem; font-weight: 500; color: #fff;
    letter-spacing: .01em;
  }
  #close-banner {
    position: absolute; right: 1rem;
    background: none; border: none; color: rgba(255,255,255,.7);
    font-size: 1.375rem; line-height: 1; cursor: pointer;
    transition: color .15s;
  }
  #close-banner:hover { color: #fff; }

  /* ── App shell ── */
  #app {
    position: fixed; left: 0; right: 0; bottom: 0; top: 2.5rem;
    display: flex;
  }

  /* ── Sidebar ── */
  #sidebar {
    width: var(--sidebar-w);
    background: var(--sidebar-bg);
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column;
    flex-shrink: 0;
    transition: width .28s cubic-bezier(.22,1,.36,1);
    position: relative; overflow: visible;
  }
  #sidebar.collapsed { width: var(--sidebar-w-c); }

  #sidebar-logo {
    height: 6rem;
    display: flex; align-items: center;
    border-bottom: 1px solid var(--border);
    padding: 0 1.5rem;
    flex-shrink: 0;
  }
  #sidebar.collapsed #sidebar-logo { justify-content: center; padding: 0; }
  #logo-link { display: flex; align-items: center; }
  #logo-img {
    height: 2.75rem;
    transition: height .28s;
  }
  #sidebar.collapsed #logo-img { height: 2rem; }

  #collapse-btn {
    position: absolute; right: -.75rem; top: 5.25rem;
    width: 1.5rem; height: 1.5rem;
    background: var(--sidebar-bg);
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--muted-fg); cursor: pointer; z-index: 10;
    transition: color .15s;
  }
  #collapse-btn:hover { color: var(--fg); }

  #sidebar-nav {
    flex: 1; padding: .75rem .625rem; display: flex; flex-direction: column; gap: .125rem;
    overflow: hidden;
  }

  .nav-item {
    width: 100%; display: flex; align-items: center; gap: .75rem;
    padding: .75rem .875rem;
    border-radius: .75rem;
    background: none; border: none;
    font-size: .9375rem; font-weight: 500;
    color: rgba(196,181,253,.55);
    cursor: pointer; text-align: left;
    transition: background .15s, color .15s;
    position: relative; white-space: nowrap;
  }
  #sidebar.collapsed .nav-item { justify-content: center; padding: .75rem; }
  .nav-item:hover:not(.active) { background: var(--muted-bg); color: var(--fg); }
  .nav-item.active { background: var(--accent-s); color: var(--accent-lt); }
  .nav-icon { flex-shrink: 0; }

  .nav-label { transition: opacity .2s; }
  #sidebar.collapsed .nav-label { display: none; }

  .active-bar {
    position: absolute; right: 0; top: 0; bottom: 0;
    width: 3px; border-radius: 2px 0 0 2px;
    background: linear-gradient(to bottom, #818cf8, #f472b6);
    opacity: 0; transition: opacity .15s;
  }
  .nav-item.active .active-bar { opacity: 1; }

  /* Footer */
  #sidebar-footer {
    padding: .75rem .625rem;
    border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: .25rem;
    flex-shrink: 0;
  }
  .footer-btn {
    width: 100%; display: flex; align-items: center; gap: .75rem;
    padding: .625rem .875rem; border-radius: .75rem;
    background: none; border: none; color: rgba(196,181,253,.45);
    font-size: .875rem; font-weight: 500; cursor: pointer;
    transition: background .15s, color .15s;
    white-space: nowrap;
  }
  .footer-btn:hover { background: var(--muted-bg); color: var(--fg); }
  #sidebar.collapsed .footer-btn { justify-content: center; }
  #sidebar.collapsed .footer-btn .nav-label { display: none; }

  #user-row {
    display: flex; align-items: center; gap: .75rem;
    padding: .5rem .875rem; border-radius: .75rem;
    transition: background .15s; cursor: default;
    white-space: nowrap;
  }
  #user-row:hover { background: var(--muted-bg); }
  #sidebar.collapsed #user-row { justify-content: center; padding: .5rem; }
  #user-avatar {
    width: 2.25rem; height: 2.25rem; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #ec4899);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: .875rem; color: #fff; flex-shrink: 0;
  }
  .nav-label-block { flex: 1; min-width: 0; }
  #sidebar.collapsed .nav-label-block { display: none; }
  #user-name { font-size: .875rem; font-weight: 600; color: var(--fg); }
  #user-email { font-size: .75rem; color: var(--muted-fg); }
  #logout-btn {
    background: none; border: none; color: var(--muted-fg);
    cursor: pointer; padding: .25rem; border-radius: .375rem;
    transition: color .15s; flex-shrink: 0;
  }
  #logout-btn:hover { color: #f87171; }
  #sidebar.collapsed #logout-btn { display: none; }

  /* ── Main ── */
  #main-content {
    flex: 1; overflow-y: auto;
    padding: 2.5rem 3rem;
    transition: padding .28s;
  }
  @media (max-width: 768px) { #main-content { padding: 1.5rem 1.25rem; } }

  /* ── Breadcrumb ── */
  .bc {
    display: flex; align-items: center; gap: .375rem;
    font-size: .875rem; color: var(--muted-fg);
    margin-bottom: 1.75rem;
  }
  .bc a { color: var(--muted-fg); text-decoration: none; transition: color .15s; cursor: pointer; }
  .bc a:hover { color: var(--fg); }
  .bc-sep { opacity: .4; font-size: .75rem; }
  .bc-current { color: var(--fg); font-weight: 500; }

  /* ── Views ── */
  .view { animation: fadeIn .18s ease-out; }
  .hidden { display: none !important; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

  /* ── Dashboard ── */
  .dash-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 1.75rem; gap: 1rem;
  }
  .display-heading {
    font-family: 'Lora', Georgia, serif;
    font-style: italic; font-weight: 600;
  }
  .muted-text { color: var(--muted-fg); }
  .gradient-text {
    background: linear-gradient(135deg, #A78BFA 0%, #f472b6 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stats-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: .875rem; padding: 1rem 1.125rem;
    display: flex; align-items: center; gap: 1rem;
    transition: border-color .2s;
  }
  .stat-card:hover { border-color: rgba(167,139,250,.3); }
  .stat-icon {
    width: 3rem; height: 3rem; border-radius: .625rem;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .stat-num { font-size: 1.5rem; font-weight: 700; }
  .stat-label { font-size: .875rem; color: var(--muted-fg); margin-top: .125rem; }

  .dash-section { margin-bottom: 1.75rem; }
  .section-toggle {
    width: 100%; display: flex; align-items: center; gap: .625rem;
    padding: 0; background: none; border: none; cursor: pointer;
    margin-bottom: 1rem; text-align: left;
  }
  .section-title { font-size: 1.0625rem; font-weight: 600; color: var(--fg); }
  .section-count { font-size: .875rem; color: var(--muted-fg); }
  .chevron {
    margin-left: auto; color: var(--muted-fg);
    transition: transform .3s cubic-bezier(.22,1,.36,1);
  }
  .chevron.collapsed { transform: rotate(-90deg); }

  .section-body {
    overflow: hidden;
    transition: max-height .36s cubic-bezier(.22,1,.36,1), opacity .3s;
    max-height: 800px; opacity: 1;
  }
  .section-body.collapsed { max-height: 0 !important; opacity: 0; }

  /* ── Post grid & cards ── */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); gap: .875rem;
  }
  @media (min-width: 640px) { .post-grid { grid-template-columns: repeat(3,1fr); } }
  @media (min-width: 1024px) { .post-grid { grid-template-columns: repeat(4,1fr); } }

  .post-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: .875rem; overflow: hidden; cursor: pointer;
    transition: border-color .2s, transform .2s, box-shadow .2s;
  }
  .post-card:hover {
    border-color: rgba(167,139,250,.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,.35);
  }
  .post-thumb { position: relative; aspect-ratio: 4/5; background: var(--bg); overflow: hidden; }
  .thumb-img { width: 100%; height: 100%; object-fit: contain; transition: transform .3s; }
  .post-card:hover .thumb-img { transform: scale(1.03); }
  .post-badge {
    position: absolute; top: .5rem; right: .5rem;
    font-size: .625rem; font-weight: 700;
    padding: .1875rem .5rem; border-radius: 9999px;
  }
  .badge-published { background: rgba(167,139,250,.18); color: #A78BFA; }
  .badge-scheduled { background: rgba(251,191,36,.15); color: #fbbf24; }
  .badge-draft { background: rgba(255,255,255,.07); color: var(--muted-fg); }
  .post-info { padding: .75rem; }
  .post-title { font-size: .875rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .post-date { font-size: .75rem; color: var(--muted-fg); margin-top: .25rem; }

  /* ── Buttons ── */
  .gradient-btn {
    background: linear-gradient(135deg, #6D28D9 0%, #A855F7 50%, #EC4899 100%);
    background-size: 200% 200%;
    color: #fff; border: none; cursor: pointer; font-weight: 700;
    font-family: inherit;
    transition: background-position .35s ease, transform .2s ease, box-shadow .2s ease, opacity .2s;
  }
  .gradient-btn:hover:not(:disabled) {
    background-position: 100% 50%;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(109,40,217,.4);
  }
  .gradient-btn:active { transform: translateY(0); }
  .gradient-btn:disabled { opacity: .4; cursor: not-allowed; }

  .outline-btn {
    background: transparent; color: var(--fg);
    border: 1px solid var(--border); border-radius: .625rem;
    padding: .625rem 1rem; font-size: .875rem; font-weight: 500;
    cursor: pointer; font-family: inherit;
    transition: border-color .2s, color .2s;
    display: flex; align-items: center; justify-content: center; gap: .375rem;
  }
  .outline-btn:hover { border-color: rgba(167,139,250,.5); color: #A78BFA; }

  .regen-btn {
    background: none; border: none; color: var(--muted-fg);
    font-size: .75rem; cursor: pointer; display: flex; align-items: center; gap: .25rem;
    transition: color .15s; font-family: inherit; padding: .25rem .375rem; border-radius: .375rem;
  }
  .regen-btn:hover { color: var(--fg); background: var(--muted-bg); }

  /* ── Composer card ── */
  #composer-card {
    background: var(--surface);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(109,40,217,.35), 0 20px 60px rgba(0,0,0,.4);
    position: relative;
  }
  #composer-card::before {
    content: '';
    position: absolute; inset: 0; border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, rgba(109,40,217,.55) 0%, rgba(168,85,247,.25) 50%, rgba(236,72,153,.15) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    pointer-events: none;
  }

  #composer-thumb { padding: 1rem 1.25rem .5rem; }
  #composer-thumb-img-wrap {
    width: 4rem; height: 4rem; border-radius: .75rem;
    overflow: hidden; border: 1px solid var(--border); background: var(--bg);
  }
  #composer-thumb-img { width: 100%; height: 100%; object-fit: cover; }
  #thumb-remove-btn {
    position: absolute; top: -.375rem; right: -.375rem;
    width: 1.25rem; height: 1.25rem; border-radius: 50%;
    background: #ef4444; color: #fff; border: none; cursor: pointer;
    font-size: .75rem; display: flex; align-items: center; justify-content: center;
  }

  #composer-textarea {
    width: 100%; background: transparent; border: none; outline: none;
    color: var(--fg); font-size: 1rem; font-family: inherit; resize: none;
    padding: 1.25rem 1.375rem 1rem;
    line-height: 1.6; min-height: 7rem;
    caret-color: var(--accent-lt);
  }
  #composer-textarea::placeholder { color: rgba(196,181,253,.35); }

  #composer-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: .625rem 1rem;
    border-top: 1px solid rgba(49,40,96,.6);
    background: rgba(13,9,32,.5);
    gap: .5rem; flex-wrap: wrap;
  }
  #composer-chips { display: flex; align-items: center; gap: .375rem; flex-wrap: wrap; }

  .chip {
    display: flex; align-items: center; gap: .375rem;
    padding: .375rem .75rem; border-radius: .5rem;
    font-size: .8125rem; font-weight: 500;
    border: 1px solid rgba(49,40,96,.7);
    background: var(--muted-bg); color: var(--muted-fg);
    cursor: pointer; transition: all .15s; font-family: inherit;
  }
  .chip:hover { background: var(--elevated); color: var(--fg); border-color: rgba(167,139,250,.3); }
  .chip.active { background: rgba(109,40,217,.12); color: var(--accent-lt); border-color: rgba(109,40,217,.35); }

  /* ── AI settings panel ── */
  #ai-settings-panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: .875rem; padding: 1.125rem 1.25rem;
    margin-top: .75rem;
    animation: fadeIn .2s;
  }
  .settings-label {
    font-size: .6875rem; font-weight: 700; letter-spacing: .08em;
    color: var(--muted-fg); text-transform: uppercase;
  }
  .settings-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: .875rem; margin-top: .875rem; }
  .settings-field-label {
    font-size: .75rem; color: var(--muted-fg); text-transform: uppercase;
    letter-spacing: .06em; display: block; margin-bottom: .375rem; margin-left: .125rem;
  }
  .settings-select {
    width: 100%; padding: .5rem .875rem; padding-right: 2rem;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: .75rem; color: var(--fg); font-size: .875rem;
    outline: none; cursor: pointer; appearance: none; font-family: inherit;
    transition: border-color .15s;
  }
  .settings-select:hover, .settings-select:focus { border-color: rgba(167,139,250,.4); }

  /* ── Preset picker ── */
  #preset-picker { margin-top: 1.25rem; animation: fadeIn .2s; }
  .preset-btn {
    position: relative; aspect-ratio: 4/5;
    background: var(--surface); border: 2px solid var(--border);
    border-radius: .75rem; overflow: hidden; cursor: pointer;
    transition: border-color .2s, transform .2s; padding: 0;
  }
  .preset-btn:hover { border-color: rgba(167,139,250,.5); transform: translateY(-2px); }
  .preset-btn.selected { border-color: var(--accent-lt); box-shadow: 0 0 0 3px rgba(167,139,250,.2); }
  .preset-label-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,.75), transparent);
    padding: .875rem .5rem .5rem;
    font-size: .75rem; font-weight: 600; color: #fff; text-align: center;
  }

  /* ── Two-panel layout ── */
  .two-panel {
    display: grid; grid-template-columns: 1fr;
    gap: 1.25rem; align-items: start;
  }
  @media (min-width: 640px) { .two-panel { grid-template-columns: 1fr 1fr; } }

  .panel-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: .875rem; overflow: hidden;
  }
  .panel-card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.125rem; border-bottom: 1px solid var(--border);
  }
  .panel-title { font-size: .9375rem; font-weight: 600; }
  .icon-circle-btn {
    width: 2rem; height: 2rem; border-radius: 50%;
    background: var(--accent-s); border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: var(--accent-lt); transition: background .15s;
  }
  .icon-circle-btn:hover { background: rgba(109,40,217,.25); }

  .product-img-wrap {
    aspect-ratio: 4/5; background: var(--bg);
    display: flex; align-items: center; justify-content: center;
  }

  /* ── Template grid ── */
  .template-grid {
    display: grid; grid-template-columns: repeat(2,1fr); gap: .625rem;
    padding: .875rem;
  }

  .tpl-btn {
    position: relative; aspect-ratio: 1/1;
    border: 2px solid transparent; border-radius: .625rem;
    overflow: hidden; cursor: pointer; padding: 0;
    transition: opacity .2s, transform .2s;
    opacity: .65;
  }
  .tpl-btn:hover { opacity: .9; }
  .tpl-btn.selected { opacity: 1; border-color: var(--accent-lt); box-shadow: 0 0 0 2px rgba(167,139,250,.25); transform: none; }
  .tpl-bg { position: absolute; inset: 0; }
  .tpl-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.6) 0%, transparent 60%);
  }
  .tpl-label {
    position: absolute; bottom: .375rem; left: 0; right: 0;
    text-align: center; font-size: .6875rem; font-weight: 700; color: #fff;
    drop-shadow: 0 1px 2px rgba(0,0,0,.5);
  }
  .tpl-check {
    position: absolute; top: .375rem; right: .375rem;
    width: 1.25rem; height: 1.25rem; border-radius: 50%;
    background: var(--accent-lt); color: #fff;
    font-size: .7rem; font-weight: 800;
    display: none; align-items: center; justify-content: center;
  }
  .tpl-btn.selected .tpl-check { display: flex; }

  .prompt-readonly {
    width: 100%; margin-top: .875rem;
    background: rgba(13,9,32,.4); border: 1px solid var(--border);
    border-radius: .875rem; padding: .875rem 1rem;
    color: var(--muted-fg); font-size: .875rem; resize: none; outline: none;
    font-family: inherit; cursor: default; line-height: 1.6;
  }

  /* ── Preview carousel ── */
  .preview-carousel {
    display: grid; grid-template-columns: repeat(3,1fr); gap: .625rem;
  }
  .preview-main-grid {
    display: grid; grid-template-columns: 1fr 18rem; gap: 1.25rem; align-items: start;
  }
  @media (max-width: 768px) { .preview-main-grid { grid-template-columns: 1fr; } }
  .preview-slot {
    position: relative; aspect-ratio: 4/5;
    background: var(--surface); border: 2px solid var(--border);
    border-radius: .75rem; overflow: hidden; cursor: pointer;
    transition: border-color .2s, transform .2s;
  }
  .preview-slot:hover:not(.loading) { border-color: rgba(167,139,250,.5); transform: translateY(-2px); }
  .preview-slot.selected { border-color: var(--accent-lt); box-shadow: 0 0 0 3px rgba(167,139,250,.2); }
  .skeleton-shimmer {
    position: absolute; inset: 0;
    background: linear-gradient(90deg, var(--surface) 0%, var(--elevated) 50%, var(--surface) 100%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .75rem;
  }
  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  .skeleton-spinner {
    width: 2rem; height: 2rem; border: 2px solid var(--border);
    border-top-color: var(--accent-lt); border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .skeleton-text { font-size: .6875rem; color: var(--muted-fg); font-weight: 500; }
  .ai-label-text { font-size: .625rem; color: var(--accent-lt); font-weight: 600; }
  .preview-slot-img { position: absolute; inset: 0; }
  .preview-slot-img img { width: 100%; height: 100%; object-fit: cover; }
  .slot-label-bar {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,.7), transparent);
    padding: .625rem .5rem .375rem; font-size: .6875rem; font-weight: 600; color: #fff;
  }
  .slot-sel-badge {
    position: absolute; top: .375rem; right: .375rem;
    background: var(--accent-lt); color: #0d0920;
    border-radius: 50%; width: 1.375rem; height: 1.375rem;
    display: flex; align-items: center; justify-content: center;
    font-size: .6875rem; font-weight: 800;
  }

  /* ── Caption styles ── */
  .caption-style-option {
    display: flex; align-items: flex-start; gap: .75rem;
    padding: .75rem .875rem; border-radius: .75rem;
    border: 1px solid var(--border);
    cursor: pointer; transition: border-color .2s, background .2s;
  }
  .caption-style-option:hover { background: var(--muted-bg); border-color: rgba(167,139,250,.3); }
  .caption-style-option.selected { border-color: var(--accent-lt); background: var(--accent-s); }
  .cap-style-dot {
    width: 1rem; height: 1rem; border-radius: 50%; flex-shrink: 0; margin-top: .125rem;
    border: 2px solid var(--border); transition: border-color .2s, background .2s;
  }
  .caption-style-option.selected .cap-style-dot { border-color: var(--accent-lt); background: var(--accent-lt); }
  .cap-style-name { font-size: .875rem; font-weight: 600; margin-bottom: .25rem; }
  .cap-style-preview { font-size: .75rem; color: var(--muted-fg); line-height: 1.5; }

  /* ── Hashtag chip ── */
  .hash-chip {
    display: inline-flex; align-items: center; gap: .25rem;
    padding: .25rem .625rem; border-radius: 9999px;
    background: rgba(167,139,250,.12); color: var(--accent-lt);
    font-size: .75rem; font-weight: 500; cursor: default;
    animation: fadeIn .25s ease-out;
  }
  .hash-chip button {
    background: none; border: none; color: inherit; cursor: pointer;
    opacity: .6; font-size: .75rem; padding: 0; line-height: 1;
    transition: opacity .15s;
  }
  .hash-chip button:hover { opacity: 1; }

  /* ── Carousel arrows ── */
  .carousel-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(13,9,32,.75); border: 1px solid rgba(167,139,250,.3);
    color: #fff; border-radius: 50%;
    width: 2.25rem; height: 2.25rem; font-size: 1.375rem; line-height: 1;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background .15s, border-color .15s; z-index: 5;
    box-shadow: 0 2px 8px rgba(0,0,0,.4);
  }
  .carousel-arrow:hover { background: rgba(109,40,217,.7); border-color: rgba(167,139,250,.6); }

  /* ── Toast ── */
  #toast {
    position: fixed; top: 1.25rem; right: 1.5rem; z-index: 100;
    animation: toastIn .3s cubic-bezier(.34,1.56,.64,1);
  }
  #toast-inner {
    display: flex; align-items: center; gap: .75rem;
    background: var(--surface); border: 1px solid rgba(167,139,250,.4);
    border-radius: 1rem; padding: .875rem 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,.5), 0 0 0 1px rgba(167,139,250,.1);
    min-width: 220px;
  }
  #toast-icon-wrap {
    width: 2.25rem; height: 2.25rem; border-radius: 50%;
    background: rgba(167,139,250,.12);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  @keyframes toastIn { from { opacity: 0; transform: translateY(-12px) scale(.95); } to { opacity: 1; transform: none; } }

  /* ── Animations ── */
  @keyframes popIn {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* ── Misc ── */
  .back-btn {
    display: inline-flex; align-items: center; gap: .375rem;
    background: none; border: none; color: var(--muted-fg); cursor: pointer;
    font-size: .875rem; font-family: inherit; padding: .25rem 0;
    transition: color .15s; margin-bottom: 1rem;
  }
  .back-btn:hover { color: var(--fg); }

  /* ── Dashboard feature cards ── */
  .dash-feature-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 640px) { .dash-feature-grid { grid-template-columns: 1fr; } }
  .dash-feature-card {
    background: var(--surface);
    border: 1px solid var(--card-border, var(--border));
    border-radius: 1rem; padding: 1.375rem;
    transition: border-color .2s, transform .2s, box-shadow .2s;
    box-shadow: inset 0 0 32px var(--card-glow, transparent);
  }
  .dash-feature-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,0,0,.3), inset 0 0 32px var(--card-glow, transparent);
  }
  .dash-feature-icon {
    width: 2.75rem; height: 2.75rem; border-radius: .75rem;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem; flex-shrink: 0;
  }
  .dash-feature-title { font-size: 1rem; font-weight: 700; margin-bottom: .5rem; }
  .dash-feature-desc { font-size: .875rem; color: var(--muted-fg); line-height: 1.6; }

  /* ── Campaigns ── */
  .camp-accordion {
    background: var(--surface); border: 1px solid rgba(109,40,217,.3);
    border-radius: .875rem; margin-bottom: 1rem; overflow: hidden;
  }
  .camp-accordion-btn {
    width: 100%; display: flex; align-items: center; gap: .625rem;
    padding: .875rem 1.125rem; background: none; border: none;
    color: var(--fg); font-size: .9375rem; font-weight: 500;
    cursor: pointer; text-align: left; font-family: inherit;
  }
  .camp-form-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;
  }
  @media (max-width: 640px) { .camp-form-grid { grid-template-columns: 1fr; } }
  .camp-upload-area {
    border: 1.5px dashed rgba(196,181,253,.2);
    border-radius: .875rem; background: rgba(196,181,253,.03);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 2rem 1rem; cursor: pointer; transition: border-color .2s, background .2s;
    min-height: 11rem; text-align: center;
  }
  .camp-upload-area:hover { border-color: rgba(167,139,250,.4); background: rgba(109,40,217,.05); }
  .camp-textarea {
    width: 100%; flex: 1;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: .75rem; padding: .75rem .875rem;
    color: var(--fg); font-size: .875rem; resize: none; outline: none;
    font-family: inherit; line-height: 1.6; transition: border-color .15s;
    min-height: 11rem;
  }
  .camp-textarea:focus { border-color: rgba(167,139,250,.4); }
  .camp-textarea::placeholder { color: rgba(196,181,253,.3); }

  /* ── Profile ── */
  .profile-grid {
    display: grid; grid-template-columns: 18rem 1fr; gap: 1.25rem; align-items: start;
  }
  @media (max-width: 900px) { .profile-grid { grid-template-columns: 1fr; } }
  .profile-section-title {
    font-size: 1rem; font-weight: 700;
    border-left: 3px solid var(--accent-lt); padding-left: .75rem;
    margin-bottom: 1.25rem;
  }
  .profile-form-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    margin-bottom: 1rem;
  }
  @media (max-width: 640px) { .profile-form-grid { grid-template-columns: 1fr; } }
  .profile-input-wrap {
    position: relative; display: flex; align-items: center;
  }
  .profile-input-icon {
    position: absolute; left: .75rem; color: var(--muted-fg); pointer-events: none; flex-shrink: 0;
  }
  .profile-input {
    width: 100%; padding: .625rem .875rem .625rem 2.25rem;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: .75rem; color: var(--fg); font-size: .875rem;
    outline: none; font-family: inherit; transition: border-color .15s;
  }
  .profile-input:focus { border-color: rgba(167,139,250,.4); }
  .activity-row {
    display: flex; align-items: center; gap: .625rem;
    padding: .625rem .75rem; border-radius: .625rem;
    background: var(--bg); border: 1px solid var(--border);
  }
  .activity-icon {
    width: 1.75rem; height: 1.75rem; border-radius: .5rem;
    background: var(--accent-s); display: flex; align-items: center; justify-content: center;
    color: var(--accent-lt); flex-shrink: 0;
  }
  .pro-plan-card {
    background: linear-gradient(135deg, rgba(109,40,217,.15) 0%, rgba(168,85,247,.07) 100%);
    border-color: rgba(109,40,217,.3) !important;
  }

  /* Instagram section */
  .ig-connected-box {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: .875rem; padding: 1rem; margin-bottom: 1.25rem;
  }
  .ig-dot-green {
    width: .5rem; height: .5rem; border-radius: 50%;
    background: #34d399; display: inline-block; flex-shrink: 0;
  }
  .ig-profile-row {
    display: flex; align-items: center; gap: .875rem;
    padding: .875rem 0; border-bottom: 1px solid var(--border); margin-bottom: 1rem;
  }
  .ig-avatar {
    width: 3rem; height: 3rem; border-radius: 50%;
    background: var(--surface); border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    overflow: hidden;
  }
  .ig-stats-grid {
    display: grid; grid-template-columns: repeat(4,1fr); gap: .5rem; margin-bottom: 1rem;
  }
  @media (max-width: 640px) { .ig-stats-grid { grid-template-columns: repeat(2,1fr); } }
  .ig-stat-cell {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: .75rem; padding: .625rem .5rem;
    display: flex; flex-direction: column; align-items: center; gap: .2rem;
    text-align: center;
  }
  .ig-stat-label { font-size: .625rem; color: var(--muted-fg); }
  .ig-stat-val { font-size: 1.0625rem; font-weight: 700; }
  .ig-stat-sub { font-size: .5625rem; color: var(--muted-fg); }
  .ig-posts-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: .375rem;
  }
  .ig-post-thumb {
    aspect-ratio: 1/1; border-radius: .5rem; overflow: hidden;
    background: var(--surface);
  }

  /* ── Settings ── */
  .settings-layout {
    display: grid; grid-template-columns: 13rem 1fr; gap: 1.25rem; align-items: start;
  }
  @media (max-width: 768px) { .settings-layout { grid-template-columns: 1fr; } }
  .settings-subnav {
    padding: .5rem; display: flex; flex-direction: column; gap: .125rem;
  }
  .settings-nav-item {
    width: 100%; display: flex; align-items: center; gap: .625rem;
    padding: .625rem .875rem; border-radius: .75rem;
    background: none; border: none; color: var(--muted-fg);
    font-size: .9rem; font-weight: 500; cursor: pointer;
    text-align: left; font-family: inherit; transition: background .15s, color .15s;
  }
  .settings-nav-item:hover:not(.active) { background: var(--muted-bg); color: var(--fg); }
  .settings-nav-item.active { background: var(--accent-s); color: var(--accent-lt); }
  .settings-section {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: .875rem; overflow: hidden;
  }
  .settings-section-hd {
    display: flex; align-items: center; gap: .875rem;
    padding: 1rem 1.25rem; border-bottom: 1px solid var(--border);
  }
  .settings-section-icon {
    width: 2.25rem; height: 2.25rem; border-radius: .625rem;
    background: var(--accent-s); display: flex; align-items: center; justify-content: center;
    color: var(--accent-lt); flex-shrink: 0;
  }
  .theme-cards-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem;
  }
  @media (max-width: 640px) { .theme-cards-grid { grid-template-columns: 1fr; } }
  .theme-card {
    border: 1px solid var(--border); border-radius: .875rem;
    padding: .875rem; cursor: pointer;
    transition: border-color .2s, background .2s;
  }
  .theme-card:hover { border-color: rgba(167,139,250,.4); }
  .theme-card.active { border-color: var(--accent-lt); background: var(--accent-s); }
  .theme-preview {
    border-radius: .5rem; padding: .875rem .75rem;
    height: 4.5rem; border: 1px solid rgba(255,255,255,.06);
  }
  .theme-dot {
    width: .875rem; height: .875rem; border-radius: 50%;
    border: 2px solid var(--border); flex-shrink: 0; margin-top: .25rem;
    transition: background .15s, border-color .15s;
  }
  .active-dot { background: var(--accent-lt); border-color: var(--accent-lt); }
  .notif-toggle-row {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: .75rem 0; border-bottom: 1px solid var(--border);
    cursor: pointer;
  }
  .notif-toggle-row:last-child { border-bottom: none; }
  .toggle-switch {
    width: 2.75rem; height: 1.5rem; border-radius: 9999px;
    background: var(--border); position: relative; flex-shrink: 0;
    cursor: pointer; transition: background .2s;
  }
  .toggle-switch.on { background: var(--accent); }
  .toggle-knob {
    position: absolute; top: .1875rem; left: .1875rem;
    width: 1.125rem; height: 1.125rem; border-radius: 50%;
    background: #fff; transition: transform .2s;
  }
  .toggle-switch.on .toggle-knob { transform: translateX(1.25rem); }
</style>

<!-- ═══════════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════════ -->
<script is:inline>
  // ── State ──────────────────────────────────────────────
  let sidebarCollapsed = false;
  let currentView = 'dashboard';
  let selectedImageSrc = '/photos-generated/non-AI.jpeg';
  let composerHasImage = false;
  let aiEnabled = true;
  let settingsOpen = false;
  let presetPickerOpen = false;
  let publishedCount = 3;
  let draftCount = 2;

  // Caption & hashtag data
  const CAPTIONS = [
    'Bu haki renkli crop ceket, dantel kollarıyla sıradan utility stilini bambaşka bir seviyeye taşıyor! Hem zarif hem de özgün bir görünüm sunan bu parça, gardırobunuzun favorisi olacak. ✨ #CropCeket #DantelCeket #UtilityStyle #FashionGoals',
    'Zarif dantel kollar ve modern kesimiyle bu haki crop ceket, gardırobunuzun en şık parçası olacak. Minimalist bir estetikle maksimum etki yaratan bu tasarım sizin için. 🌿 #Ceket #MinimalStil #ElegantFashion #DantelDetay',
    'Sıradanlığa meydan oku! ✨ Bu haki crop utility ceket, göz alıcı dantel kolları ve iddialı detaylarıyla tüm dikkatleri üzerine çekecek. Güçlü ve özgün bir görünüm için doğru seçim. 💪 #PowerDressing #StatementPiece #CeketModelleri #DantelKol',
  ];
  const HASHTAG_SETS = [
    ['moda','stil','ootd','yenikolleksiyon','instamoda','trend','günlükkombin','modablogger'],
    ['fashionista','stilinspo','yenilook','giyim','sokakstili','kombinönerileri','modahaftası','lookbook'],
    ['günlükoutfit','şıkgiyim','stilgram','modapost','trendler','trenduyarısı','kombinpost','chic'],
  ];
  let captionIdx = 0;
  let hashtagIdx = 0;
  let currentCaption = CAPTIONS[0];
  let currentHashtags = [...HASHTAG_SETS[0]];

  // Preview slots
  const PREVIEW_SLOTS = [
    { label: 'Model Dene',      src: '/photos-generated/01.png', filter: '' },
    { label: 'Düz Çekim',      src: '/photos-generated/02.png', filter: '' },
    { label: 'Kolaj',           src: '/photos-generated/03.png', filter: '' },
    { label: 'Arka Görünüm',   src: '/photos-generated/04.png', filter: '' },
    { label: 'Fotoğraf Çekimi',src: '/photos-generated/05.png', filter: '' },
    { label: 'Reklam',          src: '/photos-generated/06.png', filter: '' },
  ];
  let selectedPreviewSlots = [];
  let editorSlideIdx = 0;
  let editorImages = [];

  // ── Sidebar ─────────────────────────────────────────────
  function toggleSidebar() {
    sidebarCollapsed = !sidebarCollapsed;
    const sb = document.getElementById('sidebar');
    sb.classList.toggle('collapsed', sidebarCollapsed);
    document.getElementById('collapse-icon-left').classList.toggle('hidden', sidebarCollapsed);
    document.getElementById('collapse-icon-right').classList.toggle('hidden', !sidebarCollapsed);
    document.getElementById('main-content').style.transition = 'padding .28s';
  }

  // ── View routing ─────────────────────────────────────────
  function gotoView(key) {
    // Reset create flow when navigating to create from sidebar
    if (key === 'create') {
      document.getElementById('create-compose').classList.remove('hidden');
      document.getElementById('create-templates').classList.add('hidden');
    }

    // Hide all views
    document.querySelectorAll('.view').forEach(v => v.classList.add('hidden'));

    // Update nav active state
    document.querySelectorAll('.nav-item').forEach(btn => {
      const isActive = btn.dataset.key === key ||
        (key === 'preview' && btn.dataset.key === 'create') ||
        (key === 'editor' && btn.dataset.key === 'create');
      btn.classList.toggle('active', isActive);
    });

    currentView = key;

    // Show breadcrumb for non-dashboard views
    const bc = document.getElementById('breadcrumb');
    const bcMap = {
      create:    [['Ana Sayfa','dashboard']], current: 'Oluştur+',
      preview:   [['Ana Sayfa','dashboard'],['Oluştur+','create']], pcurrent: 'Önizleme',
      editor:    [['Ana Sayfa','dashboard'],['Oluştur+','create'],['Önizleme','preview']], ecurrent: 'Düzenle',
      scheduled: [['Ana Sayfa','dashboard']], scurrent: 'Planlanan',
      campaigns: [['Ana Sayfa','dashboard']], ccurrent: 'Kampanyalar',
      profile:   [['Ana Sayfa','dashboard']], prcurrent: 'Profil',
      settings:  [['Ana Sayfa','dashboard']], stcurrent: 'Ayarlar',
    };

    if (key !== 'dashboard') {
      bc.classList.remove('hidden');
      let html = '';
      const paths = {
        create: { parents: [['Kontrol Paneli','dashboard']], label: 'Oluştur+' },
        preview: { parents: [['Kontrol Paneli','dashboard'],['Oluştur+','create']], label: 'Önizleme' },
        editor: { parents: [['Kontrol Paneli','dashboard'],['Oluştur+','create'],['Önizleme','preview']], label: 'Düzenle' },
        scheduled: { parents: [['Kontrol Paneli','dashboard']], label: 'Planlananlar' },
        campaigns: { parents: [['Kontrol Paneli','dashboard']], label: 'Kampanyalar' },
        profile:   { parents: [['Kontrol Paneli','dashboard']], label: 'Profil' },
        settings:  { parents: [['Kontrol Paneli','dashboard']], label: 'Ayarlar' },
      };
      const crumb = paths[key];
      if (crumb) {
        html += `<button class="back-btn" onclick="gotoView('${crumb.parents[crumb.parents.length-1][1]}')" style="margin-bottom:0;margin-right:.25rem">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>`;
        crumb.parents.forEach(([label, path]) => {
          html += `<a onclick="gotoView('${path}')">${label}</a><span class="bc-sep">›</span>`;
        });
        html += `<span class="bc-current">${crumb.label}</span>`;
      }
      bc.innerHTML = html;
    } else {
      bc.classList.add('hidden');
    }

    // Show target view
    const target = document.getElementById('view-' + key);
    if (target) target.classList.remove('hidden');
  }

  // ── Dashboard ────────────────────────────────────────────
  function toggleSection(key) {
    const body = document.getElementById('section-' + key);
    const chevron = document.getElementById('chevron-' + key);
    const toggle = body.previousElementSibling;
    const collapsed = body.classList.toggle('collapsed');
    chevron.classList.toggle('collapsed', collapsed);
    toggle.setAttribute('aria-expanded', String(!collapsed));
  }

  function openPostDetail(card) {
    card.style.transform = 'scale(0.97)';
    setTimeout(() => { card.style.transform = ''; }, 150);
  }

  // ── Composer ─────────────────────────────────────────────
  function showPresetPicker() {
    presetPickerOpen = !presetPickerOpen;
    const pp = document.getElementById('preset-picker');
    pp.classList.toggle('hidden', !presetPickerOpen);
  }

  function selectPreset(src, btnId) {
    selectedImageSrc = src;
    composerHasImage = true;
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('selected'));
    document.getElementById(btnId)?.classList.add('selected');

    // Show thumbnail in composer
    const thumb = document.getElementById('composer-thumb');
    const img = document.getElementById('composer-thumb-img');
    img.src = src;
    thumb.classList.remove('hidden');

    // Update product preview img for template view
    document.getElementById('product-preview-img').src = src;

    // Update continue button
    const btnText = document.getElementById('continue-btn-text');
    btnText.textContent = 'İleri';
    const icon = document.getElementById('continue-img-icon');
    icon.style.display = 'none';

    // Close picker after slight delay
    setTimeout(() => {
      document.getElementById('preset-picker').classList.add('hidden');
      presetPickerOpen = false;
    }, 300);
  }

  function removeComposerImage() {
    composerHasImage = false;
    selectedImageSrc = '/demo-jacket.png';
    document.getElementById('composer-thumb').classList.add('hidden');
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('selected'));
    document.getElementById('continue-btn-text').textContent = 'Görsel Yükle';
    document.getElementById('continue-img-icon').style.display = '';
  }

  function toggleAI() {
    aiEnabled = !aiEnabled;
    const btn = document.getElementById('ai-toggle-btn');
    const label = document.getElementById('ai-label');
    const zapOn = document.getElementById('ai-icon-zap');
    const zapOff = document.getElementById('ai-icon-zapoff');
    const textarea = document.getElementById('composer-textarea');

    btn.classList.toggle('active', aiEnabled);
    label.textContent = aiEnabled ? 'On' : 'Off';
    zapOn.classList.toggle('hidden', !aiEnabled);
    zapOff.classList.toggle('hidden', aiEnabled);
    textarea.style.opacity = aiEnabled ? '1' : '0.4';
    textarea.disabled = !aiEnabled;
  }

  function toggleAISettings() {
    settingsOpen = !settingsOpen;
    const panel = document.getElementById('ai-settings-panel');
    panel.classList.toggle('hidden', !settingsOpen);
    document.getElementById('settings-chip').classList.toggle('active', settingsOpen);
  }

  function onComposerContinue() {
    if (!composerHasImage) {
      showPresetPicker();
      return;
    }
    // Get prompt value and show template view
    const prompt = document.getElementById('composer-textarea').value ||
      'Deri ceket, şık ve modern, sosyal medya için mükemmel';
    document.getElementById('template-prompt-display').value = prompt;
    document.getElementById('product-preview-img').src = selectedImageSrc;

    document.getElementById('create-compose').classList.add('hidden');
    document.getElementById('create-templates').classList.remove('hidden');
  }

  function backToCompose() {
    document.getElementById('create-templates').classList.add('hidden');
    document.getElementById('create-compose').classList.remove('hidden');
  }

  // ── Template selection ────────────────────────────────────
  function toggleTemplate(btn) {
    btn.classList.toggle('selected');
  }

  // ── Generate → Preview ───────────────────────────────────
  function startGenerate() {
    const btn = document.getElementById('generate-btn');
    btn.disabled = true;
    btn.innerHTML = `
      <svg style="animation:spin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Oluşturuluyor…`;

    setTimeout(() => {
      btn.disabled = false;
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/></svg>Oluştur<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>`;
      gotoView('preview');
      buildPreview();
    }, 1800);
  }

  function buildPreview() {
    selectedPreviewSlots = [];
    const grid = document.getElementById('preview-carousel');
    grid.innerHTML = PREVIEW_SLOTS.map((slot, i) => `
      <div class="preview-slot loading" id="pvslot-${i}" data-index="${i}" onclick="togglePreviewSlot(${i})">
        <div class="skeleton-shimmer" id="pvskel-${i}">
          <div class="skeleton-spinner"></div>
          <p class="skeleton-text">${slot.label}</p>
          <p class="ai-label-text">AI üretiyor…</p>
        </div>
        <div class="preview-slot-img hidden" id="pvimg-${i}">
          <img src="${slot.src}" style="filter:${slot.filter}" alt="${slot.label}"/>
          <div class="slot-label-bar">${slot.label}</div>
        </div>
      </div>
    `).join('');

    // Populate caption previews
    const shortCaptions = CAPTIONS.map(c => c.slice(0, 55) + '…');
    shortCaptions.forEach((sc, i) => {
      const el = document.getElementById('cap-preview-' + i);
      if (el) el.textContent = sc;
    });

    // Caption style click handlers
    document.querySelectorAll('.caption-style-option').forEach(opt => {
      opt.addEventListener('click', () => {
        document.querySelectorAll('.caption-style-option').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        captionIdx = parseInt(opt.dataset.idx);
        currentCaption = CAPTIONS[captionIdx];
      });
    });

    buildHashtags(document.getElementById('preview-hashtags'));

    // Staggered reveal
    const revealTimes = [800, 1400, 2000, 2600, 3200, 3800];
    revealTimes.forEach((delay, i) => {
      setTimeout(() => {
        const skel = document.getElementById('pvskel-' + i);
        const img = document.getElementById('pvimg-' + i);
        const slot = document.getElementById('pvslot-' + i);
        if (skel) skel.classList.add('hidden');
        if (img) img.classList.remove('hidden');
        if (slot) slot.classList.remove('loading');
      }, delay);
    });

    // Auto-select first slot
    setTimeout(() => togglePreviewSlot(0), 950);
  }

  function togglePreviewSlot(index) {
    const slot = document.getElementById('pvslot-' + index);
    if (!slot || slot.classList.contains('loading')) return;

    const pos = selectedPreviewSlots.indexOf(index);
    if (pos >= 0) {
      selectedPreviewSlots.splice(pos, 1);
      slot.classList.remove('selected');
      const badge = slot.querySelector('.slot-sel-badge');
      if (badge) badge.remove();
    } else {
      selectedPreviewSlots.push(index);
      slot.classList.add('selected');
    }

    // Re-number badges
    selectedPreviewSlots.forEach((idx, order) => {
      const s = document.getElementById('pvslot-' + idx);
      const existing = s.querySelector('.slot-sel-badge');
      if (existing) existing.remove();
      const badge = document.createElement('div');
      badge.className = 'slot-sel-badge';
      badge.textContent = order + 1;
      s.appendChild(badge);
    });

    // Update selection label
    const lbl = document.getElementById('preview-sel-label');
    if (lbl) lbl.textContent = `GÖRSEL SEÇ — ${selectedPreviewSlots.length} SEÇİLİ`;
  }

  function buildHashtags(container) {
    container.innerHTML = '';
    currentHashtags.forEach((tag, i) => {
      setTimeout(() => {
        const chip = document.createElement('span');
        chip.className = 'hash-chip';
        chip.innerHTML = `#${tag}<button onclick="removeHashtag(this,'${tag}',this.closest('#preview-hashtags,#editor-hashtags'))">×</button>`;
        container.appendChild(chip);
      }, i * 80);
    });
  }

  function removeHashtag(btn, tag, container) {
    btn.closest('.hash-chip').remove();
    currentHashtags = currentHashtags.filter(t => t !== tag);
  }

  function regenHashtags() {
    hashtagIdx = (hashtagIdx + 1) % HASHTAG_SETS.length;
    currentHashtags = [...HASHTAG_SETS[hashtagIdx]];
    const pvContainer = document.getElementById('preview-hashtags');
    const edContainer = document.getElementById('editor-hashtags');
    if (pvContainer && !pvContainer.closest('.hidden')) buildHashtags(pvContainer);
    if (edContainer && !edContainer.closest('.hidden')) buildHashtags(edContainer);
  }

  // ── Editor ───────────────────────────────────────────────
  function gotoEditor() {
    if (selectedPreviewSlots.length === 0) selectedPreviewSlots = [0];

    // Show ALL photos in carousel so user can swipe through like Instagram
    editorImages = [...PREVIEW_SLOTS];
    editorSlideIdx = selectedPreviewSlots[0] ?? 0;

    gotoView('editor');
    updateEditorSlide();

    const captionTA = document.getElementById('editor-caption');
    captionTA.value = currentCaption;
    updateCharCount();
    captionTA.addEventListener('input', updateCharCount);

    buildHashtags(document.getElementById('editor-hashtags'));

    buildSlideIndicator();
  }

  function updateEditorSlide() {
    if (editorImages.length === 0) return;
    const img = editorImages[editorSlideIdx];
    const el = document.getElementById('editor-main-img');
    el.src = img.src;
    el.style.filter = img.filter;
    buildSlideIndicator();

    const prevBtn = document.getElementById('editor-prev');
    const nextBtn = document.getElementById('editor-next');
    if (prevBtn) prevBtn.style.display = editorImages.length > 1 ? '' : 'none';
    if (nextBtn) nextBtn.style.display = editorImages.length > 1 ? '' : 'none';
  }

  function buildSlideIndicator() {
    const ind = document.getElementById('editor-slide-indicator');
    if (!ind || editorImages.length <= 1) { if (ind) ind.innerHTML = ''; return; }
    const selectedSrcs = new Set(selectedPreviewSlots.map(i => PREVIEW_SLOTS[i]?.src));
    ind.innerHTML = editorImages.map((img, i) => {
      const isCurrent = i === editorSlideIdx;
      const isSelected = selectedSrcs.has(img.src);
      const bg = isCurrent ? '#A78BFA' : isSelected ? 'rgba(167,139,250,.55)' : 'rgba(255,255,255,.25)';
      const size = isCurrent ? '.55rem' : '.4rem';
      return `<div style="width:${size};height:${size};border-radius:50%;background:${bg};transition:all .2s"></div>`;
    }).join('');
  }

  function editorCarousel(dir) {
    editorSlideIdx = (editorSlideIdx + dir + editorImages.length) % editorImages.length;
    updateEditorSlide();
  }

  // Touch swipe support for editor carousel
  (function() {
    let touchStartX = 0;
    document.addEventListener('DOMContentLoaded', () => {
      const wrap = document.getElementById('editor-img-wrap');
      if (!wrap) return;
      wrap.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
      wrap.addEventListener('touchend', e => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) > 40) editorCarousel(dx < 0 ? 1 : -1);
      }, { passive: true });
    });
  })();

  function updateCharCount() {
    const ta = document.getElementById('editor-caption');
    const cc = document.getElementById('editor-char-count');
    if (ta && cc) cc.textContent = `${ta.value.length} karakter`;
  }

  function regenCaption() {
    captionIdx = (captionIdx + 1) % CAPTIONS.length;
    currentCaption = CAPTIONS[captionIdx];
    const ta = document.getElementById('editor-caption');
    if (!ta) return;
    ta.value = '';
    let i = 0;
    const type = setInterval(() => {
      if (i < currentCaption.length) {
        ta.value = currentCaption.slice(0, ++i);
        updateCharCount();
      } else {
        clearInterval(type);
      }
    }, 16);
  }

  function saveDraft() {
    draftCount++;
    document.getElementById('stat-drafts').textContent = draftCount;
    document.getElementById('drafts-count').textContent = `(${draftCount})`;
    showToast('Taslak kaydedildi', 'Taslaklar bölümünde görüntüleyebilirsin');

    // Add card to drafts grid
    const grid = document.getElementById('drafts-grid');
    const card = document.createElement('div');
    card.className = 'post-card';
    card.style.animation = 'fadeIn .4s ease-out';
    card.innerHTML = `
      <div class="post-thumb">
        <img src="${editorImages[0]?.src || selectedImageSrc}" class="thumb-img" style="filter:grayscale(.4)" alt="Taslak"/>
        <span class="post-badge badge-draft">Taslak</span>
      </div>
      <div class="post-info">
        <p class="post-title muted-text">${currentCaption.slice(0,32)}…</p>
        <p class="post-date">Az önce</p>
      </div>`;
    grid.insertBefore(card, grid.firstChild);

    setTimeout(() => gotoView('dashboard'), 1200);
  }

  function schedulePost() {
    showToast('Planlandı! 📅', 'Yarın · 19:00 için planlandı');
    document.getElementById('stat-scheduled').textContent =
      parseInt(document.getElementById('stat-scheduled').textContent) + 1;
    setTimeout(() => gotoView('dashboard'), 1200);
  }

  function doPublish() {
    const btn = document.getElementById('publish-btn');
    btn.disabled = true;
    btn.innerHTML = `<svg style="animation:spin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>Yayınlanıyor…`;
    setTimeout(() => {
      publishedCount++;
      gotoView('success');
    }, 1800);
  }

  function backToDashboard() {
    // Reset create flow state
    resetCreateFlow();
    gotoView('dashboard');
  }

  function resetCreateFlow() {
    composerHasImage = false;
    selectedImageSrc = '/demo-jacket.png';
    selectedPreviewSlots = [];
    editorImages = [];
    editorSlideIdx = 0;
    document.getElementById('composer-thumb').classList.add('hidden');
    document.getElementById('continue-btn-text').textContent = 'Görsel Yükle';
    document.getElementById('continue-img-icon').style.display = '';
    document.getElementById('composer-textarea').value = '';
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('selected'));
    document.getElementById('create-compose').classList.remove('hidden');
    document.getElementById('create-templates').classList.add('hidden');
    document.getElementById('preset-picker').classList.add('hidden');
    document.getElementById('ai-settings-panel').classList.add('hidden');
    settingsOpen = false;
    presetPickerOpen = false;
  }

  // ── Campaigns ────────────────────────────────────────────
  function toggleCampTips() {
    const body = document.getElementById('camp-tips-body');
    const chevron = document.getElementById('camp-tips-chevron');
    const collapsed = body.classList.toggle('collapsed');
    chevron.classList.toggle('collapsed', collapsed);
  }
  function onCampDescInput(el) {
    const len = el.value.length;
    document.getElementById('camp-char-count').textContent = len;
    const btn = document.getElementById('create-story-btn');
    if (len > 0) {
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.cursor = 'pointer';
    } else {
      btn.disabled = true;
      btn.style.opacity = '.45';
      btn.style.cursor = 'not-allowed';
    }
  }
  function simulateCampaignCreate() {
    const btn = document.getElementById('create-story-btn');
    btn.disabled = true;
    btn.innerHTML = `<svg style="animation:spin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Oluşturuluyor…`;
    setTimeout(() => {
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/></svg> Hikaye Oluştur`;
      btn.disabled = true;
      btn.style.opacity = '.45';
      document.getElementById('campaign-desc').value = '';
      document.getElementById('camp-char-count').textContent = '0';
      showToast('Kampanya hikayesi oluşturuldu ✓', 'Gerçek uygulamada Instagram\'a gönderilir');
    }, 2000);
  }

  // ── Settings tabs ─────────────────────────────────────────
  const ALWAYS_VISIBLE_TABS = ['general','appearance','notifications'];
  function switchSettingsTab(btn) {
    const tab = btn.dataset.stab;
    document.querySelectorAll('.settings-nav-item').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    // For main 3 tabs: show all 3 always; for others show only that one
    const allSections = ['general','appearance','notifications','billing','security','whatsapp'];
    if (ALWAYS_VISIBLE_TABS.includes(tab)) {
      allSections.forEach(id => {
        const el = document.getElementById('stab-' + id);
        if (el) el.classList.toggle('hidden', !ALWAYS_VISIBLE_TABS.includes(id));
      });
    } else {
      allSections.forEach(id => {
        const el = document.getElementById('stab-' + id);
        if (el) el.classList.toggle('hidden', id !== tab);
      });
    }
  }
  function selectTheme(card) {
    document.querySelectorAll('.theme-card').forEach(c => {
      c.classList.remove('active');
      const dot = c.querySelector('.theme-dot');
      if (dot) { dot.classList.remove('active-dot'); }
    });
    card.classList.add('active');
    const dot = card.querySelector('.theme-dot');
    if (dot) dot.classList.add('active-dot');
    showToast('Tema değiştirildi','Demo modunda görsel değişim uygulanmaz');
  }
  function toggleNotif(sw) {
    sw.classList.toggle('on');
  }

  // ── Toast ────────────────────────────────────────────────
  let toastTimer = null;
  function showToast(title, sub) {
    document.getElementById('toast-title').textContent = title;
    document.getElementById('toast-sub').textContent = sub;
    const t = document.getElementById('toast');
    t.classList.remove('hidden');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(hideToast, 4000);
  }
  function hideToast() {
    document.getElementById('toast').classList.add('hidden');
  }

  // ── Logout (demo) ────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    // Banner close
    document.getElementById('close-banner')?.addEventListener('click', () => {
      document.getElementById('demo-banner').remove();
      document.getElementById('app').style.top = '0';
    });

    // Logout (just show toast)
    document.getElementById('logout-btn')?.addEventListener('click', () => {
      showToast('Demo modundasın', 'Gerçek çıkış işlemi yapılamaz');
    });

    // Theme toggle (demo — just visual)
    document.getElementById('theme-toggle-btn')?.addEventListener('click', () => {
      showToast('Tema değiştirme', 'Gerçek uygulamada 3 tema var: Violet Dusk, Lavender Light, Sanctuary');
    });
  });
</script>
