---
import '../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>TANIT — Interactive Demo</title>
  <link rel="icon" href="/tanit-logo.svg" />
</head>
<body class="bg-tanit-bg text-tanit-text font-sans antialiased overflow-hidden" style="height:100dvh">

  <!-- Demo Banner -->
  <div id="demo-banner" class="fixed top-0 left-0 right-0 z-50 flex items-center justify-center bg-tanit-purple text-white text-sm font-medium" style="height:2.5rem">
    🎮 Interactive Demo — explore freely, no account needed
    <button id="close-banner" class="absolute right-4 text-white/70 hover:text-white text-xl leading-none" aria-label="Close banner">×</button>
  </div>

  <!-- App Shell -->
  <div id="app" class="fixed left-0 right-0 bottom-0 flex flex-col" style="top:2.5rem">

    <!-- App Header -->
    <header class="flex-shrink-0 border-b border-tanit-border bg-tanit-card flex items-center px-4 gap-3 z-40" style="height:3.5rem">
      <img src="/tanit-logo.svg" alt="TANIT" style="height:2rem" />
      <div class="w-px bg-tanit-border mx-1 hidden md:block" style="height:1.5rem"></div>
      <span class="text-xs font-semibold px-2 py-1 rounded-full hidden md:inline" style="background:rgba(173,101,191,0.18);color:#AD65BF">Demo Mode</span>
      <div class="flex-1"></div>
      <a href="/" class="flex items-center gap-1.5 text-xs transition-colors px-3 py-1.5 rounded-lg hover:bg-white/5" style="color:#94a3b8">
        <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back to website
      </a>
    </header>

    <!-- Body -->
    <div class="flex flex-1 overflow-hidden">

      <!-- Sidebar -->
      <aside class="flex-shrink-0 border-r border-tanit-border bg-tanit-card flex flex-col" style="width:3.5rem" id="sidebar">
        <nav class="flex-1 p-2 flex flex-col gap-1 mt-2">
          <button id="nav-dashboard" data-nav="dashboard"
            class="nav-btn w-full flex items-center gap-3 rounded-lg text-sm font-medium transition-colors active-nav"
            style="padding:.625rem .75rem"
            onclick="switchView('dashboard')">
            <!-- Home -->
            <svg xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0" style="height:1.25rem;width:1.25rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            <span class="nav-label hidden font-medium">Dashboard</span>
          </button>
          <button id="nav-create" data-nav="create"
            class="nav-btn w-full flex items-center gap-3 rounded-lg text-sm font-medium transition-colors"
            style="padding:.625rem .75rem;color:#94a3b8"
            onclick="startCreate()">
            <!-- PlusCircle -->
            <svg xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0" style="height:1.25rem;width:1.25rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="nav-label hidden">Create Post</span>
          </button>
          <button disabled class="w-full flex items-center gap-3 rounded-lg text-sm font-medium cursor-not-allowed" style="padding:.625rem .75rem;color:rgba(148,163,184,.3)">
            <svg xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0" style="height:1.25rem;width:1.25rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="2"/><circle cx="12" cy="12" r="3" stroke-width="2"/><circle cx="17.5" cy="6.5" r=".8" fill="currentColor"/></svg>
            <span class="nav-label hidden">Instagram</span>
          </button>
          <button disabled class="w-full flex items-center gap-3 rounded-lg text-sm font-medium cursor-not-allowed" style="padding:.625rem .75rem;color:rgba(148,163,184,.3)">
            <svg xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0" style="height:1.25rem;width:1.25rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="nav-label hidden">Settings</span>
          </button>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="flex-1 overflow-y-auto" style="padding:1.5rem 2rem" id="main-content">

        <!-- ===== DASHBOARD ===== -->
        <div id="view-dashboard">
          <div style="max-width:60rem;margin:0 auto">

            <!-- Header row -->
            <div class="flex items-center justify-between" style="margin-bottom:2rem">
              <div>
                <h1 style="font-size:1.5rem;font-weight:600">Welcome back, Demo User</h1>
                <p style="color:#94a3b8;margin-top:.25rem">Here's your content overview.</p>
              </div>
              <button onclick="startCreate()" class="flex items-center gap-2 btn-primary" style="padding:.5rem 1rem;border-radius:.5rem;font-size:.875rem;font-weight:500">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Create Post
              </button>
            </div>

            <!-- Stats -->
            <div class="grid grid-cols-3 gap-4" style="margin-bottom:2rem">
              <div class="stat-card flex items-center gap-4">
                <div class="stat-icon" style="background:rgba(16,185,129,.1)">
                  <svg xmlns="http://www.w3.org/2000/svg" style="height:1.5rem;width:1.5rem;color:#34d399" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div><p id="stat-published" style="font-size:1.5rem;font-weight:700">3</p><p style="font-size:.875rem;color:#94a3b8">Published</p></div>
              </div>
              <div class="stat-card flex items-center gap-4">
                <div class="stat-icon" style="background:rgba(245,158,11,.1)">
                  <svg xmlns="http://www.w3.org/2000/svg" style="height:1.5rem;width:1.5rem;color:#fbbf24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div><p style="font-size:1.5rem;font-weight:700">1</p><p style="font-size:.875rem;color:#94a3b8">Scheduled</p></div>
              </div>
              <div class="stat-card flex items-center gap-4">
                <div class="stat-icon" style="background:rgba(59,130,246,.1)">
                  <svg xmlns="http://www.w3.org/2000/svg" style="height:1.5rem;width:1.5rem;color:#60a5fa" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <div><p style="font-size:1.5rem;font-weight:700">2</p><p style="font-size:.875rem;color:#94a3b8">Drafts</p></div>
              </div>
            </div>

            <!-- Published -->
            <section style="margin-bottom:2rem">
              <div class="flex items-center gap-2" style="margin-bottom:1rem">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1.25rem;width:1.25rem;color:#34d399" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <h2 style="font-size:1.125rem;font-weight:600">Published</h2>
                <span id="pub-count-label" style="font-size:.875rem;color:#94a3b8">(3)</span>
              </div>
              <div id="published-grid" class="post-grid">
                <div class="post-card">
                  <div class="post-thumb"><img src="/demo-post.png" class="thumb-img" alt="Post"/><span class="post-badge" style="background:rgba(16,185,129,.15);color:#34d399">Published</span></div>
                  <div class="post-info"><p class="post-title">Summer collection launch ✨</p><p class="post-date">2 days ago</p></div>
                </div>
                <div class="post-card">
                  <div class="post-thumb"><img src="/demo-photo.avif" class="thumb-img" style="filter:hue-rotate(20deg) saturate(1.3)" alt="Post"/><span class="post-badge" style="background:rgba(16,185,129,.15);color:#34d399">Published</span></div>
                  <div class="post-info"><p class="post-title">New arrivals — shop now 🛍️</p><p class="post-date">5 days ago</p></div>
                </div>
                <div class="post-card">
                  <div class="post-thumb"><img src="/demo-post.png" class="thumb-img" style="filter:brightness(.88) contrast(1.1)" alt="Post"/><span class="post-badge" style="background:rgba(16,185,129,.15);color:#34d399">Published</span></div>
                  <div class="post-info"><p class="post-title">Weekend style guide 💫</p><p class="post-date">1 week ago</p></div>
                </div>
                <!-- injected after publish -->
              </div>
            </section>

            <!-- Scheduled -->
            <section style="margin-bottom:2rem">
              <div class="flex items-center gap-2" style="margin-bottom:1rem">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1.25rem;width:1.25rem;color:#fbbf24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <h2 style="font-size:1.125rem;font-weight:600">Scheduled</h2>
                <span style="font-size:.875rem;color:#94a3b8">(1)</span>
              </div>
              <div class="post-grid">
                <div class="post-card" style="border-color:rgba(245,158,11,.25)">
                  <div class="post-thumb"><img src="/demo-photo.avif" class="thumb-img" style="filter:sepia(.3)" alt="Post"/><span class="post-badge" style="background:rgba(245,158,11,.15);color:#fbbf24">Scheduled</span></div>
                  <div class="post-info"><p class="post-title">Friday drop 🔥</p><p class="post-date" style="color:#fbbf24">Tomorrow · 7:00 PM</p></div>
                </div>
              </div>
            </section>

            <!-- Drafts -->
            <section>
              <div class="flex items-center gap-2" style="margin-bottom:1rem">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1.25rem;width:1.25rem;color:#60a5fa" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                <h2 style="font-size:1.125rem;font-weight:600">Drafts</h2>
                <span style="font-size:.875rem;color:#94a3b8">(2)</span>
              </div>
              <div class="post-grid">
                <div class="post-card">
                  <div class="post-thumb"><img src="/demo-post.png" class="thumb-img" style="filter:grayscale(.5)" alt="Draft"/><span class="post-badge" style="background:rgba(255,255,255,.07);color:#94a3b8">Draft</span></div>
                  <div class="post-info"><p class="post-title" style="color:#94a3b8">Untitled draft</p><p class="post-date">3 hours ago</p></div>
                </div>
                <div class="post-card">
                  <div class="post-thumb"><img src="/demo-photo.avif" class="thumb-img" style="filter:grayscale(.3) brightness(.85)" alt="Draft"/><span class="post-badge" style="background:rgba(255,255,255,.07);color:#94a3b8">Draft</span></div>
                  <div class="post-info"><p class="post-title" style="color:#94a3b8">Product showcase</p><p class="post-date">Yesterday</p></div>
                </div>
              </div>
            </section>

          </div>
        </div>

        <!-- ===== STEP 1: UPLOAD ===== -->
        <div id="view-create-1" class="hidden">
          <div style="max-width:56rem;margin:0 auto">
            <div class="create-header">
              <a href="#" onclick="switchView('dashboard');return false" class="icon-btn">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1.25rem;width:1.25rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
              </a>
              <div>
                <h1 style="font-size:1.25rem;font-weight:600">Create New Post</h1>
                <p style="font-size:.875rem;color:#94a3b8">Generate AI-powered content for your Instagram</p>
              </div>
            </div>
            <!-- Step indicator -->
            <div id="step-indicator-1"></div>

            <div class="content-card" style="margin-top:1.5rem">
              <h2 style="font-size:1rem;font-weight:600;margin-bottom:.25rem">Choose a product photo</h2>
              <p style="font-size:.875rem;color:#94a3b8;margin-bottom:1.5rem">Pick one of the sample images below — in the real app you'd upload your own.</p>

              <div class="grid grid-cols-2 gap-4" style="max-width:28rem">
                <button class="preset-img-btn" onclick="selectPresetImage('/demo-photo.avif', this)" id="preset-0">
                  <img src="/demo-photo.avif" class="w-full h-full object-contain" alt="Product photo" />
                  <div class="preset-label">📦 Product Photo</div>
                </button>
                <button class="preset-img-btn" onclick="selectPresetImage('/demo-post.png', this)" id="preset-1">
                  <img src="/demo-post.png" class="w-full h-full object-contain" alt="Fashion shot" />
                  <div class="preset-label">👗 Fashion Shot</div>
                </button>
              </div>

              <!-- Upload progress -->
              <div id="upload-area" class="hidden" style="margin-top:1.5rem">
                <p style="font-size:.875rem;color:#94a3b8;margin-bottom:.5rem">Uploading...</p>
                <div style="height:.375rem;background:#1f1f2e;border-radius:9999px;overflow:hidden;max-width:28rem">
                  <div id="upload-bar" style="height:100%;width:0%;background:#AD65BF;border-radius:9999px;transition:width .1s linear"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ===== STEP 2: ENHANCE ===== -->
        <div id="view-create-2" class="hidden">
          <div style="max-width:56rem;margin:0 auto">
            <div class="create-header">
              <button class="icon-btn" onclick="switchView('create-1')">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1.25rem;width:1.25rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
              </button>
              <div>
                <h1 style="font-size:1.25rem;font-weight:600">Create New Post</h1>
                <p style="font-size:.875rem;color:#94a3b8">Generate AI-powered content for your Instagram</p>
              </div>
            </div>
            <div id="step-indicator-2"></div>

            <div class="content-card" style="margin-top:1.5rem">
              <div style="margin-bottom:1rem">
                <h2 style="font-size:1rem;font-weight:600">Image Variations</h2>
                <p id="enhance-desc" style="font-size:.875rem;color:#94a3b8;margin-top:.25rem">Generating 6 variations for your product…</p>
              </div>

              <div class="enhance-grid" id="enhance-grid">
                <!-- Slots injected by JS -->
              </div>
            </div>

            <div class="flex justify-between" style="margin-top:1rem">
              <button class="btn-outline" onclick="switchView('create-1')">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Back
              </button>
              <button id="enhance-continue" class="btn-primary" disabled onclick="switchView('create-3');startGenerate()">
                Continue
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </button>
            </div>
          </div>
        </div>

        <!-- ===== STEP 3: GENERATE ===== -->
        <div id="view-create-3" class="hidden">
          <div style="max-width:56rem;margin:0 auto">
            <div class="create-header">
              <button class="icon-btn" onclick="switchView('create-2')">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1.25rem;width:1.25rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
              </button>
              <div>
                <h1 style="font-size:1.25rem;font-weight:600">Create New Post</h1>
                <p style="font-size:.875rem;color:#94a3b8">Generate AI-powered content for your Instagram</p>
              </div>
            </div>
            <div id="step-indicator-3"></div>

            <div class="grid grid-cols-1 gap-4" style="margin-top:1.5rem">

              <!-- Prompt card -->
              <div class="content-card">
                <h2 style="font-size:1rem;font-weight:600;margin-bottom:.25rem">Your Prompt</h2>
                <p style="font-size:.875rem;color:#94a3b8;margin-bottom:.75rem">Describe your product or the vibe you want</p>
                <textarea id="prompt-input" rows="3"
                  class="w-full"
                  style="background:#0a0a0f;border:1px solid #1f1f2e;border-radius:.5rem;padding:.75rem;color:#F1F1F1;font-size:.875rem;resize:none;outline:none;font-family:inherit"
                  placeholder="e.g. Elegant summer dress, beach vibes, colorful...">Stylish clothing item, elegant and modern, perfect for social media</textarea>
                <button id="generate-btn" onclick="runGenerate()" class="btn-primary w-full flex items-center justify-center gap-2" style="margin-top:.75rem">
                  <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/></svg>
                  Generate Caption &amp; Hashtags
                </button>
              </div>

              <!-- Caption card -->
              <div id="caption-card" class="content-card hidden">
                <div class="flex items-center justify-between" style="margin-bottom:.5rem">
                  <div><h2 style="font-size:1rem;font-weight:600">Caption</h2><p style="font-size:.75rem;color:#94a3b8">Edit to your liking</p></div>
                  <button onclick="regenCaption()" class="icon-btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" style="height:.875rem;width:.875rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                    Regenerate
                  </button>
                </div>
                <textarea id="caption-output" rows="4"
                  class="w-full"
                  style="background:#0a0a0f;border:1px solid #1f1f2e;border-radius:.5rem;padding:.75rem;color:#F1F1F1;font-size:.875rem;resize:none;outline:none;font-family:inherit"></textarea>
                <p id="caption-char-count" style="font-size:.75rem;color:#94a3b8;margin-top:.25rem">0 characters</p>
              </div>

              <!-- Hashtags card -->
              <div id="hashtags-card" class="content-card hidden">
                <div class="flex items-center justify-between" style="margin-bottom:.75rem">
                  <div><h2 style="font-size:1rem;font-weight:600">Hashtags</h2><p style="font-size:.75rem;color:#94a3b8">Click × to remove</p></div>
                  <button onclick="regenHashtags()" class="icon-btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" style="height:.875rem;width:.875rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                    Regenerate
                  </button>
                </div>
                <div id="hashtags-output" class="flex flex-wrap gap-2"></div>
              </div>
            </div>

            <div class="flex justify-between" style="margin-top:1rem">
              <button class="btn-outline" onclick="switchView('create-2')">
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Back
              </button>
              <button id="generate-continue" class="btn-primary" disabled onclick="switchView('create-4');buildPreview()">
                Continue to Preview
                <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </button>
            </div>
          </div>
        </div>

