  .step-text-name { font-size: .875rem; font-weight: 500; }
  .step-text-desc { font-size: .75rem; color: #94a3b8; }
  .step-line { flex: 1; height: 2px; margin: 0 1rem; }
  .step-line.done { background: #AD65BF; }
