    font-size: .75rem; font-weight: 500;
    cursor: pointer;
    transition: background .2s;
    animation: fadeInUp .3s ease-out;
  }
  .hashtag-chip:hover { background: rgba(173,101,191,.28); }

  /* ----- Preview hashtag chips ----- */
  .preview-chip {
    display: inline-flex;
    padding: .125rem .5rem;
    background: rgba(173,101,191,.15);
    color: #AD65BF;
    border-radius: 9999px;
    font-size: .75rem;
  }

  /* ----- Animations ----- */
  @keyframes spin { to { transform: rotate(360deg); } }

  @keyframes popIn {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ----- Utility ----- */
  .hidden { display: none !important; }
  .w-full { width: 100%; }
  * { box-sizing: border-box; }
</style>

<script>
  // ---- State ----
  let selectedImageSrc = '/demo-photo.avif';
  let selectedSlotIndices = []; // ordered list of selected slot indices
  let generatedCaption = '';
  let generatedHashtags = [];
  let publishedCount = 3;
  let generateRan = false;

  const SLOTS = [
    { label: 'Model Shot',   src: '/demo-post.png',   filter: '' },
    { label: 'Product Shot', src: '/demo-photo.avif', filter: 'brightness(1.05) saturate(1.1)' },
    { label: 'Close-up',     src: '/demo-post.png',   filter: 'brightness(1.1) saturate(1.2) contrast(1.05)' },
    { label: 'Back Shot',    src: '/demo-photo.avif', filter: 'hue-rotate(20deg) saturate(1.3)' },
    { label: 'Ad Visual',    src: '/demo-post.png',   filter: 'contrast(1.15) brightness(.9) saturate(.8)' },
    { label: 'Grid View',    src: '/demo-photo.avif', filter: 'sepia(.35) contrast(1.1)' },
  ];

  const CAPTIONS = [
    '✨ Elevate your everyday style with our latest collection. Crafted for those who dare to stand out. Shop now through the link in bio! 🌟',
    '🔥 New season, new look. Our curated pieces are designed for confidence and comfort. Tap the link in bio to explore! 💫',
    '💫 Style that speaks before you do. Discover our newest arrivals and make every outfit a statement. 👗 Link in bio!',
  ];
  const HASHTAG_SETS = [
    ['fashion','style','ootd','newcollection','instafashion','trendy','outfitoftheday','fashionblogger'],
    ['fashionista','styleinspo','newlook','clothing','streetstyle','outfitideas','fashionweek','lookbook'],
    ['dailyoutfit','wearitwell','stylegram','fashionpost','modafemminile','trendalert','outfitpost','chic'],
  ];
  let captionIdx = 0;
  let hashtagIdx = 0;

  // ---- View switching ----
  function switchView(viewId) {
    document.querySelectorAll('[id^="view-"]').forEach(el => el.classList.add('hidden'));
    const el = document.getElementById('view-' + viewId);
    if (el) el.classList.remove('hidden');
  }

  function setActiveNav(key) {
    document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active-nav'));
    const btn = document.getElementById('nav-' + key);
    if (btn) btn.classList.add('active-nav');
  }

  // ---- Step indicator ----
  const STEPS = [
    { name: 'Upload',   desc: 'Add product image' },
    { name: 'Enhance',  desc: 'Apply AI variations' },
    { name: 'Generate', desc: 'Caption & hashtags' },
    { name: 'Preview',  desc: 'Review and publish' },
  ];

  function renderStepIndicator(containerId, activeStep) {
    const container = document.getElementById(containerId);
    if (!container) return;
    let html = '<div class="step-indicator">';
    STEPS.forEach((step, i) => {
      const n = i + 1;
      const isDone = n < activeStep;
      const isActive = n === activeStep;
      const circleClass = isDone ? 'done' : (isActive ? 'active' : 'pending');
      const nameStyle = isActive || isDone ? 'color:#F1F1F1' : 'color:#94a3b8';
      html += `
        <div class="step-item">
          <div class="step-circle ${circleClass}">
            ${isDone
              ? '<svg xmlns="http://www.w3.org/2000/svg" style="height:1.1rem;width:1.1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>'
              : n}
          </div>
          <div class="hidden sm:block">
            <p class="step-text-name" style="${nameStyle}">${step.name}</p>
            <p class="step-text-desc">${step.desc}</p>
          </div>
        </div>`;
      if (i < STEPS.length - 1) {
        html += `<div class="step-line ${isDone ? 'done' : 'pending'}"></div>`;
      }
    });
    html += '</div>';
    container.innerHTML = html;
  }

  // ---- Dashboard ----
  function switchView_dashboard() {
    switchView('dashboard');
    setActiveNav('dashboard');
  }

  // ---- Create flow ----
  function startCreate() {
    generateRan = false;
    selectedSlotIndices = [];
    selectedImageSrc = '/demo-photo.avif';
    document.querySelectorAll('.preset-img-btn').forEach(b => b.classList.remove('selected'));
    document.getElementById('upload-area').classList.add('hidden');
    document.getElementById('upload-bar').style.width = '0%';
    switchView('create-1');
    setActiveNav('create');
    renderStepIndicator('step-indicator-1', 1);
  }

  function selectPresetImage(src, btn) {
    selectedImageSrc = src;
    document.querySelectorAll('.preset-img-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');

    // Show progress bar
    const uploadArea = document.getElementById('upload-area');
    const bar = document.getElementById('upload-bar');
    uploadArea.classList.remove('hidden');
    let w = 0;
    const interval = setInterval(() => {
      w += Math.random() * 18 + 6;
      if (w >= 100) {
        w = 100;
        bar.style.width = '100%';
        clearInterval(interval);
        setTimeout(() => {
          switchView('create-2');
          renderStepIndicator('step-indicator-2', 2);
          buildEnhanceGrid();
          startEnhanceAnimation();
        }, 350);
      }
      bar.style.width = w + '%';
    }, 80);
  }

  // ---- Enhance step ----
  function buildEnhanceGrid() {
    selectedSlotIndices = [];
    const grid = document.getElementById('enhance-grid');
    grid.innerHTML = SLOTS.map((slot, i) => `
      <div class="enhance-slot loading" id="slot-${i}" data-index="${i}" onclick="toggleSlot(${i})">
        <div class="slot-spinner" id="slot-spinner-${i}">
          <div class="spinner-ring"></div>
          <p class="slot-label-text">${slot.label}</p>
          <p class="slot-label-text" style="color:#AD65BF;font-size:.6rem">Generating…</p>
        </div>
        <div class="slot-image hidden" id="slot-image-${i}">
          <img src="${slot.src}" style="filter:${slot.filter}" alt="${slot.label}" />
          <div class="slot-image-label">${slot.label}</div>
        </div>
      </div>
    `).join('');
    document.getElementById('enhance-continue').disabled = true;
    document.getElementById('enhance-desc').textContent = 'Generating 6 variations for your product…';
  }

  function startEnhanceAnimation() {
    const revealTimes = [700, 1400, 2100, 2700, 3400, 4100];
    revealTimes.forEach((delay, i) => {
      setTimeout(() => {
        const spinner = document.getElementById(`slot-spinner-${i}`);
        const image = document.getElementById(`slot-image-${i}`);
        const slot = document.getElementById(`slot-${i}`);
        if (spinner) spinner.classList.add('hidden');
        if (image) image.classList.remove('hidden');
        if (slot) slot.classList.remove('loading');
      }, delay);
    });

    // Auto-select slot 0 once it's revealed, then enable Continue
    setTimeout(() => {
      toggleSlot(0);
      document.getElementById('enhance-continue').disabled = false;
      document.getElementById('enhance-desc').textContent = '1 selected — first tap becomes primary';
    }, 800);
  }

  function toggleSlot(index) {
    const slot = document.getElementById(`slot-${index}`);
    if (!slot || slot.classList.contains('loading')) return;

    const pos = selectedSlotIndices.indexOf(index);
    if (pos >= 0) {
      selectedSlotIndices.splice(pos, 1);
      slot.classList.remove('selected');
      const badge = slot.querySelector('.slot-badge');
      if (badge) badge.remove();
    } else {
      selectedSlotIndices.push(index);
      slot.classList.add('selected');
    }

    // Re-render badges to show order numbers
    selectedSlotIndices.forEach((idx, order) => {
      const s = document.getElementById(`slot-${idx}`);
      const existing = s.querySelector('.slot-badge');
      if (existing) existing.remove();
      const badge = document.createElement('div');
      badge.className = 'slot-badge';
      badge.textContent = order + 1;
      s.appendChild(badge);
    });

    const count = selectedSlotIndices.length;
    document.getElementById('enhance-continue').disabled = count === 0;
    document.getElementById('enhance-desc').textContent =
      count === 0
        ? 'Select at least one variation to continue'
        : `${count} selected — first tap becomes primary`;
  }

  // ---- Generate step ----
  function startGenerate() {
    generateRan = false;
    document.getElementById('caption-card').classList.add('hidden');
    document.getElementById('hashtags-card').classList.add('hidden');
    document.getElementById('hashtags-output').innerHTML = '';
    document.getElementById('caption-output').value = '';
    document.getElementById('caption-char-count').textContent = '0 characters';
    document.getElementById('generate-continue').disabled = true;
    document.getElementById('generate-btn').disabled = false;
    document.getElementById('generate-btn').innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/></svg>
      Generate Caption &amp; Hashtags`;
    renderStepIndicator('step-indicator-3', 3);
  }

  function runGenerate() {
    if (generateRan) return;
    generateRan = true;
    const btn = document.getElementById('generate-btn');
    btn.disabled = true;
    btn.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem;animation:spin 1s linear infinite" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Generating…`;

    const caption = CAPTIONS[captionIdx % CAPTIONS.length];
    const hashtags = HASHTAG_SETS[hashtagIdx % HASHTAG_SETS.length];

    setTimeout(() => {
      // Reveal caption card with typewriter
      const captionCard = document.getElementById('caption-card');
      captionCard.classList.remove('hidden');
      const output = document.getElementById('caption-output');
      const charCount = document.getElementById('caption-char-count');
      let i = 0;
      const type = setInterval(() => {
        if (i < caption.length) {
          output.value = caption.slice(0, ++i);
          charCount.textContent = `${i} characters`;
        } else {
          clearInterval(type);
          generatedCaption = caption;

          // Reveal hashtag card
          const hashtagsCard = document.getElementById('hashtags-card');
          hashtagsCard.classList.remove('hidden');
          const hashContainer = document.getElementById('hashtags-output');
          hashContainer.innerHTML = '';
          hashtags.forEach((tag, j) => {
            setTimeout(() => {
              const chip = document.createElement('span');
              chip.className = 'hashtag-chip';
              chip.innerHTML = `#${tag} <span onclick="removeHashtag(this,'${tag}')" style="opacity:.7;font-size:.7rem">×</span>`;
              hashContainer.appendChild(chip);
            }, j * 120);
          });
          generatedHashtags = [...hashtags];

          setTimeout(() => {
            document.getElementById('generate-continue').disabled = false;
            btn.disabled = false;
            btn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem;animation:spin 1s linear infinite" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`;
            btn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Regenerate All`;
            generateRan = false;
          }, hashtags.length * 120 + 200);
        }
      }, 22);
    }, 1400);
  }

  function regenCaption() {
    captionIdx++;
    const caption = CAPTIONS[captionIdx % CAPTIONS.length];
    const output = document.getElementById('caption-output');
    output.value = '';
    let i = 0;
    const type = setInterval(() => {
      if (i < caption.length) {
        output.value = caption.slice(0, ++i);
        document.getElementById('caption-char-count').textContent = `${i} characters`;
      } else {
        clearInterval(type);
        generatedCaption = caption;
      }
    }, 18);
  }

  function regenHashtags() {
    hashtagIdx++;
    const hashtags = HASHTAG_SETS[hashtagIdx % HASHTAG_SETS.length];
    const hashContainer = document.getElementById('hashtags-output');
    hashContainer.innerHTML = '';
    hashtags.forEach((tag, j) => {
      setTimeout(() => {
        const chip = document.createElement('span');
        chip.className = 'hashtag-chip';
        chip.innerHTML = `#${tag} <span onclick="removeHashtag(this,'${tag}')" style="opacity:.7;font-size:.7rem">×</span>`;
        hashContainer.appendChild(chip);
      }, j * 100);
    });
    generatedHashtags = [...hashtags];
  }

  function removeHashtag(el, tag) {
    el.parentElement.remove();
    generatedHashtags = generatedHashtags.filter(t => t !== tag);
  }

  // ---- Preview step ----
  function buildPreview() {
    renderStepIndicator('step-indicator-4', 4);

    // Pick the primary selected image (first selected slot, fallback to selectedImageSrc)
    const primarySlotIdx = selectedSlotIndices[0];
    const primarySrc = primarySlotIdx !== undefined
      ? SLOTS[primarySlotIdx].src
      : selectedImageSrc;
    const primaryFilter = primarySlotIdx !== undefined ? SLOTS[primarySlotIdx].filter : '';

    const previewImg = document.getElementById('preview-image');
    previewImg.src = primarySrc;
    previewImg.style.filter = primaryFilter;

    const caption = document.getElementById('caption-output')?.value || generatedCaption;
    generatedCaption = caption;

    document.getElementById('preview-caption-text').innerHTML =
      `<strong>your_brand</strong> ${caption.slice(0, 80)}${caption.length > 80 ? '…' : ''}`;
    document.getElementById('preview-caption-panel').textContent = caption;

    const tags = generatedHashtags.length ? generatedHashtags
      : Array.from(document.querySelectorAll('.hashtag-chip'))
          .map(el => el.textContent.replace('×','').trim().replace('#',''));

    document.getElementById('preview-hashtag-text').textContent = tags.map(t => '#' + t).join(' ');

    const panelContainer = document.getElementById('preview-hashtags-panel');
    panelContainer.innerHTML = tags.map(t =>
      `<span class="preview-chip">#${t}</span>`
    ).join('');

    // Reset publish button
    const btn = document.getElementById('publish-btn');
    btn.disabled = false;
    btn.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" style="height:1.125rem;width:1.125rem" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
      Publish to Instagram`;
  }

  function doPublish() {
    const btn = document.getElementById('publish-btn');
    btn.disabled = true;
    btn.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" style="height:1rem;width:1rem;animation:spin 1s linear infinite" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Publishing…`;
    setTimeout(() => {
      publishedCount++;
      switchView('success');
    }, 1600);
  }

  function backToDashboard() {
    // Update stat counter
    document.getElementById('stat-published').textContent = publishedCount;
    document.getElementById('pub-count-label').textContent = `(${publishedCount})`;

    // Inject new post card
    const grid = document.getElementById('published-grid');
    const primarySlotIdx = selectedSlotIndices[0];
    const src = primarySlotIdx !== undefined ? SLOTS[primarySlotIdx].src : selectedImageSrc;
    const filter = primarySlotIdx !== undefined ? SLOTS[primarySlotIdx].filter : '';
    const captionSnippet = generatedCaption ? generatedCaption.slice(0, 40) + '…' : 'New post';

    const card = document.createElement('div');
    card.className = 'post-card';
    card.style.borderColor = 'rgba(173,101,191,.5)';
    card.style.animation = 'fadeInUp .4s ease-out';
    card.innerHTML = `
      <div class="post-thumb">
        <img src="${src}" class="thumb-img" style="filter:${filter}" alt="New post" />
        <span class="post-badge" style="background:rgba(173,101,191,.2);color:#AD65BF">Just published ✨</span>
      </div>
      <div class="post-info">
        <p class="post-title">${captionSnippet}</p>
        <p class="post-date">Just now</p>
      </div>`;
    grid.insertBefore(card, grid.firstChild);

    switchView('dashboard');
    setActiveNav('dashboard');
  }

  // ---- Banner ----
  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('close-banner')?.addEventListener('click', () => {
      document.getElementById('demo-banner').remove();
      document.getElementById('app').style.top = '0';
    });

    // Wire up nav dashboard button
    document.getElementById('nav-dashboard')?.addEventListener('click', () => {
      switchView('dashboard');
      setActiveNav('dashboard');
    });
  });
</script>
