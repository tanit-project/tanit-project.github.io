    background: #0a0a0f;
    border: 2px solid #1f1f2e;
    border-radius: .625rem;
    overflow: hidden;
    cursor: pointer;
    transition: border-color .2s;
  }
  .enhance-slot.selected { border-color: #AD65BF; box-shadow: 0 0 0 3px rgba(173,101,191,.2); }
  .enhance-slot:hover:not(.loading) { border-color: rgba(173,101,191,.5); }

  .slot-spinner {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .5rem;
    background: rgba(18,18,26,.95);
  }
  .spinner-ring {
    width: 2rem; height: 2rem;
    border: 2px solid #1f1f2e;
    border-top-color: #AD65BF;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  .slot-label-text { font-size: .7rem; color: #94a3b8; font-weight: 500; }

  .slot-image { position: absolute; inset: 0; }
  .slot-image img { width: 100%; height: 100%; object-fit: cover; }
  .slot-image-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,.65), transparent);
    padding: .5rem .375rem .375rem;
    font-size: .625rem; font-weight: 600; color: #fff;
  }
  .slot-badge {
    position: absolute; top: .375rem; right: .375rem;
    width: 1.25rem; height: 1.25rem;
    background: #AD65BF; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .625rem; font-weight: 700; color: #fff;
  }

  /* ----- Hashtag chip ----- */
  .hashtag-chip {
    display: inline-flex; align-items: center; gap: .25rem;
