      document.getElementById('create-compose').classList.remove('hidden');
      document.getElementById('create-templates').classList.add('hidden');
    }

    // Hide all views
    document.querySelectorAll('.view').forEach(v => v.classList.add('hidden'));

    // Update nav active state
    document.querySelectorAll('.nav-item').forEach(btn => {
      const isActive = btn.dataset.key === key ||
        (key === 'preview' && btn.dataset.key === 'create') ||
        (key === 'editor' && btn.dataset.key === 'create');
      btn.classList.toggle('active', isActive);
    });

    currentView = key;

    // Show breadcrumb for non-dashboard views
    const bc = document.getElementById('breadcrumb');
    const bcMap = {
      create:    [['Ana Sayfa','dashboard']], current: 'Oluştur+',
      preview:   [['Ana Sayfa','dashboard'],['Oluştur+','create']], pcurrent: 'Önizleme',
      editor:    [['Ana Sayfa','dashboard'],['Oluştur+','create'],['Önizleme','preview']], ecurrent: 'Düzenle',
      scheduled: [['Ana Sayfa','dashboard']], scurrent: 'Planlanan',
      campaigns: [['Ana Sayfa','dashboard']], ccurrent: 'Kampanyalar',
      profile:   [['Ana Sayfa','dashboard']], prcurrent: 'Profil',
      settings:  [['Ana Sayfa','dashboard']], stcurrent: 'Ayarlar',
    };

    if (key !== 'dashboard') {
      bc.classList.remove('hidden');
      let html = '';
      const paths = {
        create: { parents: [['Ana Sayfa','dashboard']], label: 'Oluştur+' },
        preview: { parents: [['Ana Sayfa','dashboard'],['Oluştur+','create']], label: 'Önizleme' },
        editor: { parents: [['Ana Sayfa','dashboard'],['Oluştur+','create'],['Önizleme','preview']], label: 'Düzenle' },
        scheduled: { parents: [['Ana Sayfa','dashboard']], label: 'Planlanan' },
        campaigns: { parents: [['Ana Sayfa','dashboard']], label: 'Kampanyalar' },
        profile:   { parents: [['Ana Sayfa','dashboard']], label: 'Profil' },
        settings:  { parents: [['Ana Sayfa','dashboard']], label: 'Ayarlar' },
      };
      const crumb = paths[key];
      if (crumb) {
        html += `<button class="back-btn" onclick="gotoView('${crumb.parents[crumb.parents.length-1][1]}')" style="margin-bottom:0;margin-right:.25rem">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>`;
        crumb.parents.forEach(([label, path]) => {
          html += `<a onclick="gotoView('${path}')">${label}</a><span class="bc-sep">›</span>`;
        });
        html += `<span class="bc-current">${crumb.label}</span>`;
      }
      bc.innerHTML = html;
    } else {
      bc.classList.add('hidden');
    }

    // Show target view
    const target = document.getElementById('view-' + key);
    if (target) target.classList.remove('hidden');
  }

  // ── Dashboard ────────────────────────────────────────────
  function toggleSection(key) {
    const body = document.getElementById('section-' + key);
    const chevron = document.getElementById('chevron-' + key);
    const toggle = body.previousElementSibling;
    const collapsed = body.classList.toggle('collapsed');
    chevron.classList.toggle('collapsed', collapsed);
    toggle.setAttribute('aria-expanded', String(!collapsed));
  }

  function openPostDetail(card) {
    card.style.transform = 'scale(0.97)';
    setTimeout(() => { card.style.transform = ''; }, 150);
  }

  // ── Composer ─────────────────────────────────────────────
  function showPresetPicker() {
    presetPickerOpen = !presetPickerOpen;
    const pp = document.getElementById('preset-picker');
    pp.classList.toggle('hidden', !presetPickerOpen);
  }

  function selectPreset(src, btnId) {
    selectedImageSrc = src;
    composerHasImage = true;
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('selected'));
    document.getElementById(btnId)?.classList.add('selected');

    // Show thumbnail in composer
    const thumb = document.getElementById('composer-thumb');
    const img = document.getElementById('composer-thumb-img');
    img.src = src;
    thumb.classList.remove('hidden');

    // Update product preview img for template view
    document.getElementById('product-preview-img').src = src;

    // Update continue button
    const btnText = document.getElementById('continue-btn-text');
    btnText.textContent = 'İleri';
    const icon = document.getElementById('continue-img-icon');
    icon.style.display = 'none';

    // Close picker after slight delay
    setTimeout(() => {
      document.getElementById('preset-picker').classList.add('hidden');
      presetPickerOpen = false;
    }, 300);
  }

  function removeComposerImage() {
    composerHasImage = false;
    selectedImageSrc = '/demo-photo.avif';
    document.getElementById('composer-thumb').classList.add('hidden');
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('selected'));
    document.getElementById('continue-btn-text').textContent = 'Fotoğraf Seç';
    document.getElementById('continue-img-icon').style.display = '';
  }

  function toggleAI() {
    aiEnabled = !aiEnabled;
    const btn = document.getElementById('ai-toggle-btn');
    const label = document.getElementById('ai-label');
    const zapOn = document.getElementById('ai-icon-zap');
    const zapOff = document.getElementById('ai-icon-zapoff');
    const textarea = document.getElementById('composer-textarea');

    btn.classList.toggle('active', aiEnabled);
    label.textContent = aiEnabled ? 'On' : 'Off';
    zapOn.classList.toggle('hidden', !aiEnabled);
    zapOff.classList.toggle('hidden', aiEnabled);
    textarea.style.opacity = aiEnabled ? '1' : '0.4';
    textarea.disabled = !aiEnabled;
  }

  function toggleAISettings() {
    settingsOpen = !settingsOpen;
    const panel = document.getElementById('ai-settings-panel');
    panel.classList.toggle('hidden', !settingsOpen);
    document.getElementById('settings-chip').classList.toggle('active', settingsOpen);
  }

  function onComposerContinue() {
    if (!composerHasImage) {
      showPresetPicker();
      return;
    }
    // Get prompt value and show template view
    const prompt = document.getElementById('composer-textarea').value ||
      'Deri ceket, şık ve modern, sosyal medya için mükemmel';
    document.getElementById('template-prompt-display').value = prompt;
    document.getElementById('product-preview-img').src = selectedImageSrc;

    document.getElementById('create-compose').classList.add('hidden');
    document.getElementById('create-templates').classList.remove('hidden');
  }

  function backToCompose() {
    document.getElementById('create-templates').classList.add('hidden');
    document.getElementById('create-compose').classList.remove('hidden');
  }

  // ── Template selection ────────────────────────────────────
  function toggleTemplate(btn) {
    btn.classList.toggle('selected');
  }

  // ── Generate → Preview ───────────────────────────────────
  function startGenerate() {
    const btn = document.getElementById('generate-btn');
    btn.disabled = true;
    btn.innerHTML = `
      <svg style="animation:spin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Oluşturuluyor…`;

    setTimeout(() => {
      btn.disabled = false;
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/></svg>Oluştur<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>`;
      gotoView('preview');
      buildPreview();
    }, 1800);
  }

  function buildPreview() {
    selectedPreviewSlots = [];
    const grid = document.getElementById('preview-carousel');
    grid.innerHTML = PREVIEW_SLOTS.map((slot, i) => `
      <div class="preview-slot loading" id="pvslot-${i}" data-index="${i}" onclick="togglePreviewSlot(${i})">
        <div class="skeleton-shimmer" id="pvskel-${i}">
          <div class="skeleton-spinner"></div>
          <p class="skeleton-text">${slot.label}</p>
          <p class="ai-label-text">AI üretiyor…</p>
        </div>
        <div class="preview-slot-img hidden" id="pvimg-${i}">
          <img src="${slot.src}" style="filter:${slot.filter}" alt="${slot.label}"/>
          <div class="slot-label-bar">${slot.label}</div>
        </div>
      </div>
    `).join('');

    // Populate caption previews
    const shortCaptions = CAPTIONS.map(c => c.slice(0, 55) + '…');
    shortCaptions.forEach((sc, i) => {
      const el = document.getElementById('cap-preview-' + i);
      if (el) el.textContent = sc;
    });

    // Caption style click handlers
    document.querySelectorAll('.caption-style-option').forEach(opt => {
      opt.addEventListener('click', () => {
        document.querySelectorAll('.caption-style-option').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        captionIdx = parseInt(opt.dataset.idx);
        currentCaption = CAPTIONS[captionIdx];
      });
    });

    buildHashtags(document.getElementById('preview-hashtags'));

    // Staggered reveal
    const revealTimes = [900, 1800, 2800, 3700];
    revealTimes.forEach((delay, i) => {
      setTimeout(() => {
        const skel = document.getElementById('pvskel-' + i);
        const img = document.getElementById('pvimg-' + i);
        const slot = document.getElementById('pvslot-' + i);
        if (skel) skel.classList.add('hidden');
        if (img) img.classList.remove('hidden');
        if (slot) slot.classList.remove('loading');
      }, delay);
    });

    // Auto-select first slot
    setTimeout(() => togglePreviewSlot(0), 950);
  }

  function togglePreviewSlot(index) {
    const slot = document.getElementById('pvslot-' + index);
    if (!slot || slot.classList.contains('loading')) return;

    const pos = selectedPreviewSlots.indexOf(index);
    if (pos >= 0) {
      selectedPreviewSlots.splice(pos, 1);
      slot.classList.remove('selected');
      const badge = slot.querySelector('.slot-sel-badge');
      if (badge) badge.remove();
    } else {
      selectedPreviewSlots.push(index);
      slot.classList.add('selected');
    }

    // Re-number badges
    selectedPreviewSlots.forEach((idx, order) => {
      const s = document.getElementById('pvslot-' + idx);
      const existing = s.querySelector('.slot-sel-badge');
      if (existing) existing.remove();
      const badge = document.createElement('div');
      badge.className = 'slot-sel-badge';
      badge.textContent = order + 1;
      s.appendChild(badge);
    });
  }

  function buildHashtags(container) {
    container.innerHTML = '';
    currentHashtags.forEach((tag, i) => {
      setTimeout(() => {
        const chip = document.createElement('span');
        chip.className = 'hash-chip';
        chip.innerHTML = `#${tag}<button onclick="removeHashtag(this,'${tag}',this.closest('#preview-hashtags,#editor-hashtags'))">×</button>`;
        container.appendChild(chip);
      }, i * 80);
    });
  }

  function removeHashtag(btn, tag, container) {
    btn.closest('.hash-chip').remove();
    currentHashtags = currentHashtags.filter(t => t !== tag);
  }

  function regenHashtags() {
    hashtagIdx = (hashtagIdx + 1) % HASHTAG_SETS.length;
    currentHashtags = [...HASHTAG_SETS[hashtagIdx]];
    const pvContainer = document.getElementById('preview-hashtags');
    const edContainer = document.getElementById('editor-hashtags');
    if (pvContainer && !pvContainer.closest('.hidden')) buildHashtags(pvContainer);
    if (edContainer && !edContainer.closest('.hidden')) buildHashtags(edContainer);
  }

  // ── Editor ───────────────────────────────────────────────
  function gotoEditor() {
    if (selectedPreviewSlots.length === 0) selectedPreviewSlots = [0];

    editorImages = selectedPreviewSlots.map(i => PREVIEW_SLOTS[i]);
    editorSlideIdx = 0;

    gotoView('editor');
    updateEditorSlide();

    const captionTA = document.getElementById('editor-caption');
    captionTA.value = currentCaption;
    updateCharCount();
    captionTA.addEventListener('input', updateCharCount);

    buildHashtags(document.getElementById('editor-hashtags'));

    // Slide indicator
    buildSlideIndicator();
  }

  function updateEditorSlide() {
    if (editorImages.length === 0) return;
    const img = editorImages[editorSlideIdx];
    const el = document.getElementById('editor-main-img');
    el.src = img.src;
    el.style.filter = img.filter;
    buildSlideIndicator();

    const prevBtn = document.getElementById('editor-prev');
    const nextBtn = document.getElementById('editor-next');
    if (prevBtn) prevBtn.style.display = editorImages.length > 1 ? '' : 'none';
    if (nextBtn) nextBtn.style.display = editorImages.length > 1 ? '' : 'none';
  }

  function buildSlideIndicator() {
    const ind = document.getElementById('editor-slide-indicator');
    if (!ind || editorImages.length <= 1) { if (ind) ind.innerHTML = ''; return; }
    ind.innerHTML = editorImages.map((_, i) =>
      `<div style="width:.5rem;height:.5rem;border-radius:50%;background:${i===editorSlideIdx ? '#A78BFA' : 'rgba(167,139,250,.3)'};transition:background .2s"></div>`
    ).join('');
  }

  function editorCarousel(dir) {
    editorSlideIdx = (editorSlideIdx + dir + editorImages.length) % editorImages.length;
    updateEditorSlide();
  }

  function updateCharCount() {
    const ta = document.getElementById('editor-caption');
    const cc = document.getElementById('editor-char-count');
    if (ta && cc) cc.textContent = `${ta.value.length} karakter`;
  }

  function regenCaption() {
    captionIdx = (captionIdx + 1) % CAPTIONS.length;
    currentCaption = CAPTIONS[captionIdx];
    const ta = document.getElementById('editor-caption');
    if (!ta) return;
    ta.value = '';
    let i = 0;
    const type = setInterval(() => {
      if (i < currentCaption.length) {
        ta.value = currentCaption.slice(0, ++i);
        updateCharCount();
      } else {
        clearInterval(type);
      }
    }, 16);
  }

  function saveDraft() {
    draftCount++;
    document.getElementById('stat-drafts').textContent = draftCount;
    document.getElementById('drafts-count').textContent = `(${draftCount})`;
    showToast('Taslak kaydedildi', 'Taslaklar bölümünde görüntüleyebilirsin');

    // Add card to drafts grid
    const grid = document.getElementById('drafts-grid');
    const card = document.createElement('div');
    card.className = 'post-card';
    card.style.animation = 'fadeIn .4s ease-out';
    card.innerHTML = `
      <div class="post-thumb">
        <img src="${editorImages[0]?.src || selectedImageSrc}" class="thumb-img" style="filter:grayscale(.4)" alt="Taslak"/>
        <span class="post-badge badge-draft">Taslak</span>
      </div>
      <div class="post-info">
        <p class="post-title muted-text">${currentCaption.slice(0,32)}…</p>
        <p class="post-date">Az önce</p>
      </div>`;
    grid.insertBefore(card, grid.firstChild);

    setTimeout(() => gotoView('dashboard'), 1200);
  }

  function schedulePost() {
    showToast('Planlandı! 📅', 'Yarın · 19:00 için planlandı');
    document.getElementById('stat-scheduled').textContent =
      parseInt(document.getElementById('stat-scheduled').textContent) + 1;
    setTimeout(() => gotoView('dashboard'), 1200);
  }

  function doPublish() {
    const btn = document.getElementById('publish-btn');
    btn.disabled = true;
    btn.innerHTML = `<svg style="animation:spin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>Yayınlanıyor…`;
    setTimeout(() => {
      publishedCount++;
      gotoView('success');
    }, 1800);
  }

  function backToDashboard() {
    document.getElementById('stat-published').textContent = publishedCount;
    document.getElementById('pub-count').textContent = `(${publishedCount})`;

    // Inject new published card
    const grid = document.getElementById('published-grid');
    const src = editorImages[0]?.src || selectedImageSrc;
    const filter = editorImages[0]?.filter || '';
    const caption = currentCaption.slice(0, 36) + '…';
    const card = document.createElement('div');
    card.className = 'post-card';
    card.style.animation = 'fadeIn .4s ease-out';
    card.style.borderColor = 'rgba(167,139,250,.45)';
    card.innerHTML = `
      <div class="post-thumb">
        <img src="${src}" class="thumb-img" style="filter:${filter}" alt="Yeni gönderi"/>
        <span class="post-badge badge-published">Az önce ✨</span>
      </div>
      <div class="post-info">
        <p class="post-title">${caption}</p>
        <p class="post-date">Az önce</p>
      </div>`;
    grid.insertBefore(card, grid.firstChild);

    // Reset create flow state
    resetCreateFlow();
    gotoView('dashboard');
  }

  function resetCreateFlow() {
    composerHasImage = false;
    selectedImageSrc = '/demo-photo.avif';
    selectedPreviewSlots = [];
    editorImages = [];
    editorSlideIdx = 0;
    document.getElementById('composer-thumb').classList.add('hidden');
    document.getElementById('continue-btn-text').textContent = 'Fotoğraf Seç';
    document.getElementById('continue-img-icon').style.display = '';
    document.getElementById('composer-textarea').value = '';
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('selected'));
    document.getElementById('create-compose').classList.remove('hidden');
    document.getElementById('create-templates').classList.add('hidden');
    document.getElementById('preset-picker').classList.add('hidden');
    document.getElementById('ai-settings-panel').classList.add('hidden');
    settingsOpen = false;
    presetPickerOpen = false;
  }

  // ── Toast ────────────────────────────────────────────────
  let toastTimer = null;
  function showToast(title, sub) {
    document.getElementById('toast-title').textContent = title;
    document.getElementById('toast-sub').textContent = sub;
    const t = document.getElementById('toast');
    t.classList.remove('hidden');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(hideToast, 4000);
  }
  function hideToast() {
    document.getElementById('toast').classList.add('hidden');
  }

  // ── Logout (demo) ────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    // Banner close
    document.getElementById('close-banner')?.addEventListener('click', () => {
      document.getElementById('demo-banner').remove();
      document.getElementById('app').style.top = '0';
    });

    // Logout (just show toast)
    document.getElementById('logout-btn')?.addEventListener('click', () => {
      showToast('Demo modundasın', 'Gerçek çıkış işlemi yapılamaz');
    });

    // Theme toggle (demo — just visual)
    document.getElementById('theme-toggle-btn')?.addEventListener('click', () => {
      showToast('Tema değiştirme', 'Gerçek uygulamada 3 tema var: Violet Dusk, Lavender Light, Sanctuary');
    });
  });
</script>
