---
import { Icon } from 'astro-icon/components';

const teamMembers = [
  { name: "Sümeyye Acar", image: "/team-photos/sumeyye.png" },
  { name: "M. Furkan Başıbüyük", image: "/team-photos/furkan.jpeg" },
  { name: "Kutay Buyruk", image: "/team-photos/kutay.png" },
  { name: "Ömer Bıçakcıoğlu", image: "/team-photos/omer.png" },
  { name: "Betül Doğrul", image: "/team-photos/betul.png" },
];
---

<section id="team" class="py-20 md:py-28 relative overflow-hidden">
  <div class="container-custom relative">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="animate-on-scroll delay-0 inline-flex items-center gap-2 px-4 py-2 glass-light rounded-full mb-6">
        <Icon name="ph:users-three" class="h-4 w-4 text-tanit-purple" />
        <span class="text-sm font-medium text-tanit-text-muted">Our Team</span>
      </div>
      <h2 class="animate-on-scroll delay-1 text-3xl md:text-4xl lg:text-5xl font-bold text-tanit-text">
        Meet the <span class="gradient-text">minds</span> behind TANIT
      </h2>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 mb-16">
      {teamMembers.map((member, index) => (
        <div class={`animate-on-scroll delay-${index % 3 + 2} group`}>
          <div class="team-card h-full">
            <div class="relative aspect-square overflow-hidden">
              <div class="absolute inset-0 bg-tanit-purple/50"></div>
              <img src={member.image} alt={member.name} loading="lazy" class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-110" onerror="this.style.display='none'" />
              <div class="absolute inset-0 flex items-center justify-center">
                <Icon name="ph:user" class="h-16 w-16 text-tanit-purple/30" />
              </div>
            </div>
            <div class="p-4 text-center">
              <h3 class="font-semibold text-tanit-text text-sm md:text-base">{member.name}</h3>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="animate-on-scroll delay-5 text-center">
      <div class="glass-card inline-block p-6 md:p-8">
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 rounded-full bg-tanit-purple flex items-center justify-center">
            <Icon name="ph:graduation-cap" class="h-8 w-8 text-white" />
          </div>
          <div class="text-left">
            <p class="text-sm text-tanit-text-muted">Supervisor</p>
            <h3 class="text-xl font-bold text-tanit-text">Cevdet Aykanat</h3>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
