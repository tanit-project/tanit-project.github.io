---
import { Icon } from 'astro-icon/components';
---

<section class="relative min-h-screen flex items-center pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="orb orb-purple w-[600px] h-[600px] -top-40 -left-40 animate-float"></div>
    <div class="orb orb-purple w-[500px] h-[500px] top-1/2 -right-40 animate-float" style="animation-delay: -2s;"></div>
  </div>
  
  <div class="container-custom relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="text-center lg:text-left">
        <div class="animate-on-scroll delay-0 inline-flex items-center gap-2 px-4 py-2 glass-light rounded-full mb-6">
          <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
          <span class="text-sm font-medium text-tanit-text-muted">CS 491 Senior Design Project</span>
        </div>
        
        <h1 class="animate-on-scroll delay-1 text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold leading-tight text-tanit-text">
          Your <span class="gradient-text">AI Social Media Manager.</span> <br class="hidden md:block" />Reimagined.
        </h1>
        
        <p class="animate-on-scroll delay-2 mt-6 text-lg md:text-xl text-tanit-text-muted max-w-xl mx-auto lg:mx-0">
          Turn a simple product photo into a professional Instagram campaign in seconds. <strong class="text-tanit-text">No design skills needed.</strong>
        </p>
        
        <div class="animate-on-scroll delay-3 mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#features" class="btn btn-glow px-8 py-4 text-lg">
            <Icon name="ph:play" class="h-5 w-5 mr-2" />
            Try TANIT Demo
          </a>
          <a href="#how-it-works" class="btn btn-secondary px-8 py-4 text-lg">
            Learn More
          </a>
        </div>
      </div>
      
      <!-- AI Transformation Demo -->
      <div class="animate-on-scroll delay-4">
        <div class="relative">
          <div class="absolute -inset-4 bg-tanit-purple/20 rounded-3xl blur-3xl opacity-50"></div>
          <div class="relative glass-card p-6 md:p-8 rounded-3xl">
            <div class="flex items-center justify-between mb-6">
              <span class="text-sm font-medium text-tanit-text-muted">AI Transformation</span>
              <div class="flex gap-1">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
            </div>
            
            <!-- Transformation Grid -->
            <div class="grid grid-cols-[1fr,auto,1fr] gap-3 md:gap-6 items-center">
              
              <!-- Before: Raw Photo with Drag Animation -->
              <div class="relative group" id="before-photo">
                <div class="aspect-square rounded-xl overflow-hidden border-2 border-dashed border-white/20 relative bg-gray-800/50">
                  <img 
                    src="/demo-photo.avif" 
                    alt="Raw product photo" 
                    class="w-full h-full object-cover"
                  />
                  <!-- Mouse drag animation overlay -->
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                    <div id="drag-cursor" class="opacity-0">
                      <div class="w-8 h-8 bg-white rounded-full shadow-lg flex items-center justify-center">
                        <Icon name="ph:cursor" class="h-4 w-4 text-gray-800" />
                      </div>
                    </div>
                  </div>
                </div>
                <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-gray-700 rounded-full text-xs text-tanit-text-muted border border-white/10 whitespace-nowrap">
                  📷 Your Photo
                </div>
              </div>
              
              <!-- Arrow Animation -->
              <div class="flex flex-col items-center gap-2">
                <div id="transform-arrow" class="relative">
                  <div class="w-12 h-12 rounded-full bg-tanit-purple flex items-center justify-center shadow-glow-md transform-arrow-glow">
                    <Icon name="ph:arrow-right" class="h-6 w-6 text-white" />
                  </div>
                  <!-- Particles -->
                  <div class="particles absolute inset-0 pointer-events-none">
                    <span class="particle"></span>
                    <span class="particle"></span>
                    <span class="particle"></span>
                  </div>
                </div>
                <span class="text-xs text-tanit-purple font-medium">AI Magic</span>
              </div>
              
              <!-- After: Instagram Post Mockup -->
              <div class="relative" id="after-post">
                <div class="bg-white rounded-xl overflow-hidden shadow-2xl border border-white/20 instagram-post">
                  <!-- Instagram Header -->
                  <div class="flex items-center gap-2 p-2 bg-white border-b border-gray-100">
                    <div class="w-6 h-6 rounded-full bg-gradient-to-br from-purple-500 to-pink-500"></div>
                    <span class="text-[10px] font-semibold text-gray-800">your_brand</span>
                    <Icon name="ph:dots-three" class="h-4 w-4 text-gray-400 ml-auto" />
                  </div>
                  <!-- Post Image -->
                  <div class="aspect-square overflow-hidden">
                    <img 
                      src="/demo-post.png" 
                      alt="AI generated Instagram post" 
                      class="w-full h-full object-cover"
                    />
                  </div>
                  <!-- Instagram Actions -->
                  <div class="p-2 bg-white">
                    <div class="flex items-center gap-3 mb-1">
                      <Icon name="ph:heart" class="h-5 w-5 text-gray-800" />
                      <Icon name="ph:chat-circle" class="h-5 w-5 text-gray-800" />
                      <Icon name="ph:paper-plane-tilt" class="h-5 w-5 text-gray-800" />
                      <Icon name="ph:bookmark-simple" class="h-5 w-5 text-gray-800 ml-auto" />
                    </div>
                    <p class="text-[8px] text-gray-800 leading-tight line-clamp-2">
                      <span class="font-semibold">your_brand</span> Check out our latest! ✨ 
                      <span class="text-blue-500">#fashion #style #newcollection</span>
                    </p>
                  </div>
                </div>
                <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-tanit-purple rounded-full text-xs text-white whitespace-nowrap shadow-glow-sm">
                  ✨ Ready to Post
                </div>
              </div>
            </div>
            
            <!-- Generated Content Info -->
            <div class="mt-8 space-y-2">
              <div class="flex items-center gap-3 p-3 glass-light rounded-lg generated-item" style="animation-delay: 0.5s;">
                <Icon name="ph:text-aa" class="h-5 w-5 text-tanit-purple" />
                <span class="text-sm text-tanit-text-muted flex-1">Caption generated</span>
                <Icon name="ph:check-circle" class="h-5 w-5 text-green-400" />
              </div>
              <div class="flex items-center gap-3 p-3 glass-light rounded-lg generated-item" style="animation-delay: 1s;">
                <Icon name="ph:hash" class="h-5 w-5 text-tanit-purple" />
                <span class="text-sm text-tanit-text-muted flex-1">Hashtags selected</span>
                <Icon name="ph:check-circle" class="h-5 w-5 text-green-400" />
              </div>
              <div class="flex items-center gap-3 p-3 glass-light rounded-lg generated-item" style="animation-delay: 1.5s;">
                <Icon name="ph:clock" class="h-5 w-5 text-tanit-purple" />
                <span class="text-sm text-tanit-text-muted flex-1">Best time to post: 7:00 PM</span>
                <Icon name="ph:check-circle" class="h-5 w-5 text-green-400" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Transform Arrow Glow Animation */
  .transform-arrow-glow {
    animation: arrowPulse 2s ease-in-out infinite;
  }
  
  @keyframes arrowPulse {
    0%, 100% {
      box-shadow: 0 0 20px rgba(173, 101, 191, 0.5), 0 0 40px rgba(173, 101, 191, 0.3);
      transform: scale(1);
    }
    50% {
      box-shadow: 0 0 30px rgba(173, 101, 191, 0.8), 0 0 60px rgba(173, 101, 191, 0.5);
      transform: scale(1.1);
    }
  }
  
  /* Particles Animation */
  .particle {
    position: absolute;
    width: 6px;
    height: 6px;
    background: #AD65BF;
    border-radius: 50%;
    animation: particleFly 2s ease-out infinite;
  }
  
  .particle:nth-child(1) { animation-delay: 0s; top: 50%; left: 50%; }
  .particle:nth-child(2) { animation-delay: 0.3s; top: 30%; left: 50%; }
  .particle:nth-child(3) { animation-delay: 0.6s; top: 70%; left: 50%; }
  
  @keyframes particleFly {
    0% {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
    100% {
      opacity: 0;
      transform: translateX(30px) scale(0);
    }
  }
  
  /* Instagram Post Entrance */
  .instagram-post {
    animation: postReveal 3s ease-out infinite;
  }
  
  @keyframes postReveal {
    0%, 20% {
      opacity: 0.3;
      transform: scale(0.95);
      filter: blur(2px);
    }
    40%, 100% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
  }
  
  /* Generated Items Animation */
  .generated-item {
    animation: itemSlideIn 0.5s ease-out forwards;
    opacity: 0;
    transform: translateX(-10px);
  }
  
  @keyframes itemSlideIn {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  /* Drag Cursor Animation */
  #drag-cursor {
    animation: dragMotion 4s ease-in-out infinite;
  }
  
  @keyframes dragMotion {
    0%, 100% {
      opacity: 0;
      transform: translate(-30px, 30px);
    }
    10% {
      opacity: 1;
      transform: translate(-30px, 30px);
    }
    30% {
      opacity: 1;
      transform: translate(0, 0);
    }
    50% {
      opacity: 1;
      transform: translate(30px, -20px);
    }
    60% {
      opacity: 0;
      transform: translate(50px, -30px);
    }
  }
</style>
