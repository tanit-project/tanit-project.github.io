---
import { Icon } from 'astro-icon/components';
---

<section class="relative min-h-screen flex items-center pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="orb orb-purple w-[600px] h-[600px] -top-40 -left-40 animate-float"></div>
    <div class="orb orb-purple w-[500px] h-[500px] top-1/2 -right-40 animate-float" style="animation-delay: -2s;"></div>
  </div>
  
  <div class="container-custom relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="text-center lg:text-left">
        <div class="animate-on-scroll delay-0 inline-flex items-center gap-2 px-4 py-2 glass-light rounded-full mb-6">
          <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
          <span class="text-sm font-medium text-tanit-text-muted">CS 491 Senior Design Project</span>
        </div>
        
        <h1 class="animate-on-scroll delay-1 text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold leading-tight text-tanit-text">
          Your <span class="gradient-text">AI Social Media Manager.</span> <br class="hidden md:block" />Reimagined.
        </h1>
        
        <p class="animate-on-scroll delay-2 mt-6 text-lg md:text-xl text-tanit-text-muted max-w-xl mx-auto lg:mx-0">
          Turn a simple product photo into a professional Instagram campaign in seconds. <strong class="text-tanit-text">No design skills needed.</strong>
        </p>
        
        <div class="animate-on-scroll delay-3 mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <button id="open-video-modal" class="btn btn-glow px-8 py-4 text-lg">
            <Icon name="ph:play" class="h-5 w-5 mr-2" />
            Watch TANIT Demo
          </button>
          <a href="#how-it-works" class="btn btn-secondary px-8 py-4 text-lg">
            Learn More
          </a>
        </div>
      </div>
      
      <!-- AI Transformation Demo -->
      <div class="animate-on-scroll delay-4">
        <div class="relative">
          <div class="absolute -inset-4 bg-tanit-purple/20 rounded-3xl blur-3xl opacity-50"></div>
          <div class="relative glass-card p-6 md:p-8 rounded-3xl">
            <div class="flex items-center justify-between mb-6">
              <span class="text-sm font-medium text-tanit-text-muted">AI Transformation</span>
              <div class="flex gap-1">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
            </div>
            
            <!-- Transformation Grid -->
            <div class="grid grid-cols-[1fr,auto,1fr] gap-3 md:gap-6 items-center">
              
              <!-- Before: Raw Photo with Drag Animation -->
              <div class="relative group" id="before-photo">
                <div class="aspect-square rounded-xl overflow-hidden border-2 border-dashed border-white/20 relative bg-gray-800/50">
                  <img 
                    src="/demo-photo.avif" 
                    alt="Raw product photo" 
                    class="w-full h-full object-cover"
                  />
                  <!-- Mouse drag animation overlay -->
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                    <div id="drag-cursor" class="opacity-0">
                      <div class="w-8 h-8 bg-white rounded-full shadow-lg flex items-center justify-center">
                        <Icon name="ph:cursor" class="h-4 w-4 text-gray-800" />
                      </div>
                    </div>
                  </div>
                </div>
                <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-gray-700 rounded-full text-xs text-tanit-text-muted border border-white/10 whitespace-nowrap">
                  📷 Your Photo
                </div>
              </div>
              
              <!-- Arrow Animation -->
              <div class="flex flex-col items-center gap-2">
                <div id="transform-arrow" class="relative">
                  <div class="w-12 h-12 rounded-full bg-tanit-purple flex items-center justify-center shadow-glow-md transform-arrow-glow">
                    <Icon name="ph:arrow-right" class="h-6 w-6 text-white" />
                  </div>
                  <!-- Particles -->
                  <div class="particles absolute inset-0 pointer-events-none">
                    <span class="particle"></span>
                    <span class="particle"></span>
                    <span class="particle"></span>
                  </div>
                </div>
                <span class="text-xs text-tanit-purple font-medium">AI Magic</span>
              </div>
              
              <!-- After: Instagram Post Mockup -->
              <div class="relative" id="after-post">
                <div class="bg-white rounded-xl overflow-hidden shadow-2xl border border-white/20 instagram-post">
                  <!-- Instagram Header -->
                  <div class="flex items-center gap-2 p-2 bg-white border-b border-gray-100">
                    <div class="w-6 h-6 rounded-full bg-gradient-to-br from-purple-500 to-pink-500"></div>
                    <span class="text-[10px] font-semibold text-gray-800">your_brand</span>
                    <Icon name="ph:dots-three" class="h-4 w-4 text-gray-400 ml-auto" />
                  </div>
                  <!-- Post Image -->
                  <div class="aspect-square overflow-hidden">
                    <img 
                      src="/demo-post.png" 
                      alt="AI generated Instagram post" 
                      class="w-full h-full object-cover"
                    />
                  </div>
                  <!-- Instagram Actions -->
                  <div class="p-2 bg-white">
                    <div class="flex items-center gap-3 mb-1">
                      <Icon name="ph:heart" class="h-5 w-5 text-gray-800" />
                      <Icon name="ph:chat-circle" class="h-5 w-5 text-gray-800" />
                      <Icon name="ph:paper-plane-tilt" class="h-5 w-5 text-gray-800" />
                      <Icon name="ph:bookmark-simple" class="h-5 w-5 text-gray-800 ml-auto" />
                    </div>
                    <p class="text-[8px] text-gray-800 leading-tight line-clamp-2">
                      <span class="font-semibold">your_brand</span> Check out our latest! ✨ 
                      <span class="text-blue-500">#fashion #style #newcollection</span>
                    </p>
                  </div>
                </div>
                <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-tanit-purple rounded-full text-xs text-white whitespace-nowrap shadow-glow-sm">
                  ✨ Ready to Post
                </div>
              </div>
            </div>
            
            <!-- Generated Content Info -->
            <div class="mt-8 space-y-2">
              <div class="flex items-center gap-3 p-3 glass-light rounded-lg generated-item" style="animation-delay: 0.5s;">
                <Icon name="ph:text-aa" class="h-5 w-5 text-tanit-purple" />
                <span class="text-sm text-tanit-text-muted flex-1">Caption generated</span>
                <Icon name="ph:check-circle" class="h-5 w-5 text-green-400" />
              </div>
              <div class="flex items-center gap-3 p-3 glass-light rounded-lg generated-item" style="animation-delay: 1s;">
                <Icon name="ph:hash" class="h-5 w-5 text-tanit-purple" />
                <span class="text-sm text-tanit-text-muted flex-1">Hashtags selected</span>
                <Icon name="ph:check-circle" class="h-5 w-5 text-green-400" />
              </div>
              <div class="flex items-center gap-3 p-3 glass-light rounded-lg generated-item" style="animation-delay: 1.5s;">
                <Icon name="ph:clock" class="h-5 w-5 text-tanit-purple" />
                <span class="text-sm text-tanit-text-muted flex-1">Best time to post: 7:00 PM</span>
                <Icon name="ph:check-circle" class="h-5 w-5 text-green-400" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Transform Arrow Glow Animation */
  .transform-arrow-glow {
    animation: arrowPulse 2s ease-in-out infinite;
  }
  
  @keyframes arrowPulse {
    0%, 100% {
      box-shadow: 0 0 20px rgba(173, 101, 191, 0.5), 0 0 40px rgba(173, 101, 191, 0.3);
      transform: scale(1);
    }
    50% {
      box-shadow: 0 0 30px rgba(173, 101, 191, 0.8), 0 0 60px rgba(173, 101, 191, 0.5);
      transform: scale(1.1);
    }
  }
  
  /* Particles Animation */
  .particle {
    position: absolute;
    width: 6px;
    height: 6px;
    background: #AD65BF;
    border-radius: 50%;
    animation: particleFly 2s ease-out infinite;
  }
  
  .particle:nth-child(1) { animation-delay: 0s; top: 50%; left: 50%; }
  .particle:nth-child(2) { animation-delay: 0.3s; top: 30%; left: 50%; }
  .particle:nth-child(3) { animation-delay: 0.6s; top: 70%; left: 50%; }
  
  @keyframes particleFly {
    0% {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
    100% {
      opacity: 0;
      transform: translateX(30px) scale(0);
    }
  }
  
  /* Instagram Post Entrance */
  .instagram-post {
    animation: postReveal 3s ease-out infinite;
  }
  
  @keyframes postReveal {
    0%, 20% {
      opacity: 0.3;
      transform: scale(0.95);
      filter: blur(2px);
    }
    40%, 100% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
  }
  
  /* Generated Items Animation */
  .generated-item {
    animation: itemSlideIn 0.5s ease-out forwards;
    opacity: 0;
    transform: translateX(-10px);
  }
  
  @keyframes itemSlideIn {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  /* Drag Cursor Animation */
  #drag-cursor {
    animation: dragMotion 4s ease-in-out infinite;
  }

  @keyframes dragMotion {
    0%, 100% {
      opacity: 0;
      transform: translate(-30px, 30px);
    }
    10% {
      opacity: 1;
      transform: translate(-30px, 30px);
    }
    30% {
      opacity: 1;
      transform: translate(0, 0);
    }
    50% {
      opacity: 1;
      transform: translate(30px, -20px);
    }
    60% {
      opacity: 0;
      transform: translate(50px, -30px);
    }
  }

  /* Video Modal */
  #video-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  #video-modal.open {
    display: flex;
  }
  #video-modal-box {
    background: #1a1025;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 1.5rem;
    width: 100%;
    max-width: 860px;
    padding: 2rem;
    position: relative;
    box-shadow: 0 0 80px rgba(173,101,191,0.25);
  }
  #video-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(255,255,255,0.07);
    border: none;
    color: #ccc;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  #video-modal-close:hover { background: rgba(255,255,255,0.15); }

  .video-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .video-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1rem;
    padding: 1.25rem 1rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    text-align: center;
  }
  .video-card:hover {
    background: rgba(173,101,191,0.12);
    border-color: rgba(173,101,191,0.4);
    transform: translateY(-2px);
  }
  .video-card-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: rgba(173,101,191,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .video-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #e2d4f0;
    line-height: 1.3;
  }
  .video-card-sub {
    font-size: 0.75rem;
    color: #9b8ab0;
  }
  #video-player-wrap {
    display: none;
    margin-top: 1.25rem;
    flex-direction: column;
    gap: 0.75rem;
  }
  #video-player-wrap.show { display: flex; }
  #video-back-btn {
    background: none;
    border: none;
    color: #ad65bf;
    cursor: pointer;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0;
    width: fit-content;
  }
  #video-back-btn:hover { color: #c890da; }
  #video-iframe-wrap {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    border-radius: 0.75rem;
    overflow: hidden;
    background: #000;
  }
  #video-iframe-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>

<!-- Video Selection Modal -->
<div id="video-modal" role="dialog" aria-modal="true" aria-labelledby="video-modal-title">
  <div id="video-modal-box">
    <button id="video-modal-close" aria-label="Kapat">×</button>
    <h2 id="video-modal-title" style="font-size:1.25rem;font-weight:700;color:#e2d4f0;">TANIT Demo Videolarını İzle</h2>
    <p style="font-size:0.85rem;color:#9b8ab0;margin-top:0.25rem;">Keşfetmek istediğin videoyu seç</p>

    <div class="video-cards" id="video-cards">
      <div class="video-card" data-id="147L-Ij86oav5V6jtB7p9y6IMbWPn4giv" data-title="Brand DNA">
        <div class="video-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#ad65bf" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <div>
          <div class="video-card-title">Brand DNA</div>
          <div class="video-card-sub">Marka kimliği oluşturma</div>
        </div>
      </div>

      <div class="video-card" data-id="1lPifPTdPsTeq9B7kIEiQDFuo9UZMllXG" data-title="Kampanya">
        <div class="video-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#ad65bf" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
        </div>
        <div>
          <div class="video-card-title">Kampanya</div>
          <div class="video-card-sub">AI kampanya yönetimi</div>
        </div>
      </div>

      <div class="video-card" data-id="1waSKtyfRFPHF5xICoYeyYUPhXXaOh1wD" data-title="Model Paylaşımı">
        <div class="video-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#ad65bf" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98"/></svg>
        </div>
        <div>
          <div class="video-card-title">Model Paylaşımı</div>
          <div class="video-card-sub">İçerik yayınlama akışı</div>
        </div>
      </div>
    </div>

    <div id="video-player-wrap">
      <button id="video-back-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Videolara geri dön
      </button>
      <div id="video-iframe-wrap">
        <iframe id="video-iframe" src="" allowfullscreen allow="autoplay"></iframe>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('video-modal');
  const closeBtn = document.getElementById('video-modal-close');
  const openBtn = document.getElementById('open-video-modal');
  const cards = document.getElementById('video-cards');
  const playerWrap = document.getElementById('video-player-wrap');
  const backBtn = document.getElementById('video-back-btn');
  const iframe = document.getElementById('video-iframe');

  openBtn?.addEventListener('click', () => modal?.classList.add('open'));

  function closeModal() {
    modal?.classList.remove('open');
    iframe.src = '';
    cards.style.display = '';
    playerWrap.classList.remove('show');
  }

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  document.querySelectorAll('.video-card').forEach(card => {
    card.addEventListener('click', () => {
      const fileId = card.dataset.id;
      iframe.src = `https://drive.google.com/file/d/${fileId}/preview`;
      cards.style.display = 'none';
      playerWrap.classList.add('show');
    });
  });

  backBtn?.addEventListener('click', () => {
    iframe.src = '';
    cards.style.display = '';
    playerWrap.classList.remove('show');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
