---
import { Icon } from 'astro-icon/components';

const steps = [
  { number: "1", title: "Upload", description: "Upload a product photo or send it to WhatsApp.", icon: "ph:upload-simple" },
  { number: "2", title: "Generate", description: "AI creates design, caption, and hashtags.", icon: "ph:magic-wand" },
  { number: "3", title: "Schedule", description: "One-click publish or schedule for optimal time.", icon: "ph:clock" }
];
---

<section id="how-it-works" class="py-20 md:py-28 relative overflow-hidden">
  <div class="container-custom relative">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="animate-on-scroll delay-0 inline-flex items-center gap-2 px-4 py-2 glass-light rounded-full mb-6">
        <Icon name="ph:play" class="h-4 w-4 text-tanit-purple" />
        <span class="text-sm font-medium text-tanit-text-muted">Simple Process</span>
      </div>
      <h2 class="animate-on-scroll delay-1 text-3xl md:text-4xl lg:text-5xl font-bold text-tanit-text">
        Three steps to <span class="gradient-text">social media success</span>
      </h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <div class="hidden md:block absolute top-24 left-[20%] right-[20%] h-0.5 bg-tanit-purple/50"></div>
      
      {steps.map((step, index) => (
        <div class={`animate-on-scroll delay-${index + 2} relative`}>
          <div class="glass-card p-8 text-center group h-full">
            <div class="relative inline-flex mb-6">
              <div class="w-20 h-20 rounded-2xl bg-tanit-purple/20 flex items-center justify-center transition-all duration-300 group-hover:bg-tanit-purple/30 group-hover:shadow-glow-md">
                <Icon name={step.icon} class="h-10 w-10 text-tanit-purple" />
              </div>
              <div class="absolute -top-2 -right-2 w-8 h-8 rounded-full bg-tanit-purple flex items-center justify-center text-white text-sm font-bold">{step.number}</div>
            </div>
            <h3 class="text-2xl font-bold text-tanit-text mb-3">{step.title}</h3>
            <p class="text-tanit-text-muted leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
