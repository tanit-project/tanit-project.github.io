---
import { Icon } from 'astro-icon/components';

const navLinks = [
  { name: 'Features', href: '#features' },
  { name: 'How it Works', href: '#how-it-works' },
  { name: 'Team', href: '#team' },
];
---

<footer class="relative pt-20 pb-8 overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-tanit-purple/50"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-tanit-card to-transparent opacity-50"></div>
  
  <div class="container-custom relative">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-12 border-b border-white/5">
      <div class="md:col-span-1">
        <a href="/" class="inline-flex items-center transition-transform duration-300 hover:scale-105" aria-label="TANIT home">
          <img src="/tanit-logo.svg" alt="TANIT" class="h-14" />
        </a>
        <p class="mt-4 text-tanit-text-muted max-w-md">
          AI-powered Instagram content creation and management for small businesses.
        </p>
        <div class="mt-6 flex gap-4">
          <a href="https://github.com/tanit-project/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg glass-light flex items-center justify-center text-tanit-text-muted hover:text-tanit-text transition-all duration-300" aria-label="GitHub">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
          </a>
        </div>
      </div>
      
      <div>
        <h3 class="text-sm font-semibold text-tanit-text uppercase tracking-wider mb-4">Navigation</h3>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li><a href={link.href} class="text-tanit-text-muted hover:text-tanit-text transition-colors duration-300">{link.name}</a></li>
          ))}
        </ul>
      </div>
      
      <div>
        <h3 class="text-sm font-semibold text-tanit-text uppercase tracking-wider mb-4">Project</h3>
        <ul class="space-y-3 text-tanit-text-muted">
          <li>CS 491 Senior Design</li>
          <li>Bilkent University</li>
          <li>2024-2025 Academic Year</li>
        </ul>
      </div>
    </div>
    
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-tanit-text-muted text-center md:text-left">© {new Date().getFullYear()} TANIT Team. Bilkent University.</p>
      <p class="text-sm text-tanit-text-muted">Made with <span class="text-tanit-purple">♥</span> by CS 491 students</p>
    </div>
  </div>
</footer>
