---
import { Icon } from 'astro-icon/components';

const navItems = [
  { name: 'Features', href: '#features' },
  { name: 'How it Works', href: '#how-it-works' },
  { name: 'Team', href: '#team' },
];
---

<header class="fixed top-0 z-50 w-full bg-tanit-bg/80 backdrop-blur-xl border-b border-white/5" role="banner">
  <div class="container-custom flex items-center justify-between h-20">
    <a href="/" class="flex items-center transition-transform duration-300 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-tanit-purple focus:ring-offset-2 focus:ring-offset-tanit-bg rounded-lg" aria-label="TANIT home">
      <img src="/tanit-logo.svg" alt="TANIT" class="h-16" />
    </a>
    
    <nav class="hidden md:flex items-center space-x-8" role="navigation" aria-label="Main navigation">
      {navItems.map(item => (
        <a href={item.href} class="text-tanit-text-muted hover:text-tanit-text transition-all duration-300 font-medium">
          {item.name}
        </a>
      ))}
    </nav>
    
    <div class="flex items-center space-x-4">
      <!-- Reports Dropdown -->
      <div class="hidden md:block relative group">
        <button class="inline-flex items-center gap-2 text-tanit-text-muted hover:text-tanit-text transition-all duration-300 px-3 py-2 rounded-lg hover:bg-white/5">
          <Icon name="ph:file-text" class="h-5 w-5" />
          <span>Reports</span>
          <Icon name="ph:caret-down" class="h-4 w-4" />
        </button>
        <div class="absolute right-0 mt-2 w-72 glass-card p-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <a href="https://docs.google.com/viewer?url=https://tanit-project.github.io/reports/T2530_Analysis_and_Requirements_Report.docx" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/10 transition-colors">
            <Icon name="ph:file-text" class="h-5 w-5 text-tanit-purple" />
            <div>
              <p class="text-sm text-tanit-text font-medium">Analysis & Requirements</p>
              <p class="text-xs text-tanit-text-muted">T2530 Report</p>
            </div>
          </a>
          <a href="https://docs.google.com/viewer?url=https://tanit-project.github.io/reports/T2530_Project_Specification_Document.docx" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/10 transition-colors">
            <Icon name="ph:file-text" class="h-5 w-5 text-tanit-purple" />
            <div>
              <p class="text-sm text-tanit-text font-medium">Project Specification</p>
              <p class="text-xs text-tanit-text-muted">T2530 Document</p>
            </div>
          </a>
          <a href="https://drive.google.com/file/d/1sqTrgV3whZkpVdAGqWBQKl3T6dXLqGZr/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/10 transition-colors">
            <Icon name="ph:file-text" class="h-5 w-5 text-tanit-purple" />
            <div>
              <p class="text-sm text-tanit-text font-medium">Detailed Design Report</p>
              <p class="text-xs text-tanit-text-muted">Design Document</p>
            </div>
          </a>
        </div>
      </div>
      
      <div class="hidden md:block relative group">
        <button class="inline-flex items-center gap-2 text-tanit-text-muted hover:text-tanit-text transition-all duration-300 px-3 py-2 rounded-lg hover:bg-white/5">
          <Icon name="ph:github-logo" class="h-5 w-5" />
          <span>GitHub</span>
          <Icon name="ph:caret-down" class="h-4 w-4" />
        </button>
        <div class="absolute right-0 mt-2 w-72 glass-card p-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <a href="https://github.com/smyy1001/TANIT" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/10 transition-colors">
            <Icon name="ph:github-logo" class="h-5 w-5 text-tanit-purple" />
            <div>
              <p class="text-sm text-tanit-text font-medium">Implementation</p>
              <p class="text-xs text-tanit-text-muted">Core Repository</p>
            </div>
          </a>
          <a href="https://github.com/tanit-project/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/10 transition-colors">
            <Icon name="ph:github-logo" class="h-5 w-5 text-tanit-purple" />
            <div>
              <p class="text-sm text-tanit-text font-medium">tanit-project.github.io</p>
              <p class="text-xs text-tanit-text-muted">Website Repository</p>
            </div>
          </a>
        </div>
      </div>
      <a href="/demo" class="btn btn-glow px-6 py-2.5 text-sm">Get Started Free</a>
      
      <button id="menu-toggle" class="md:hidden flex items-center p-2 text-tanit-text-muted hover:text-tanit-text transition-colors rounded-lg hover:bg-white/5" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  
  <nav id="mobile-menu" class="hidden md:hidden bg-tanit-bg/95 backdrop-blur-xl w-full border-t border-white/5" role="navigation" aria-label="Mobile navigation">
    <div class="container-custom py-6 space-y-4">
      {navItems.map((item) => (
        <a href={item.href} class="block py-3 px-4 text-tanit-text-muted hover:text-tanit-text hover:bg-white/5 rounded-lg transition-all duration-300">
          {item.name}
        </a>
      ))}
      <div class="border-t border-white/10 pt-4 mt-4">
        <p class="px-4 text-xs text-tanit-text-muted uppercase tracking-wider mb-2">Reports</p>
        <a href="https://docs.google.com/viewer?url=https://tanit-project.github.io/reports/T2530_Analysis_and_Requirements_Report.docx" target="_blank" rel="noopener noreferrer" class="block py-3 px-4 text-tanit-text-muted hover:text-tanit-text hover:bg-white/5 rounded-lg transition-all duration-300">
          Analysis & Requirements
        </a>
        <a href="https://docs.google.com/viewer?url=https://tanit-project.github.io/reports/T2530_Project_Specification_Document.docx" target="_blank" rel="noopener noreferrer" class="block py-3 px-4 text-tanit-text-muted hover:text-tanit-text hover:bg-white/5 rounded-lg transition-all duration-300">
          Project Specification
        </a>
        <a href="https://drive.google.com/file/d/1sqTrgV3whZkpVdAGqWBQKl3T6dXLqGZr/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="block py-3 px-4 text-tanit-text-muted hover:text-tanit-text hover:bg-white/5 rounded-lg transition-all duration-300">
          Detailed Design Report
        </a>
      </div>
      <div class="border-t border-white/10 pt-4 mt-4">
        <p class="px-4 text-xs text-tanit-text-muted uppercase tracking-wider mb-2">GitHub</p>
        <a href="https://github.com/smyy1001/TANIT" target="_blank" rel="noopener noreferrer" class="block py-3 px-4 text-tanit-text-muted hover:text-tanit-text hover:bg-white/5 rounded-lg transition-all duration-300">
          Implementation
        </a>
        <a href="https://github.com/tanit-project/" target="_blank" rel="noopener noreferrer" class="block py-3 px-4 text-tanit-text-muted hover:text-tanit-text hover:bg-white/5 rounded-lg transition-all duration-300">
          tanit-project.github.io
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    
    menuToggle?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
      mobileMenu?.classList.toggle('mobile-menu-open');
      const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', String(!isExpanded));
    });

    const header = document.querySelector('header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    });
  });
</script>
